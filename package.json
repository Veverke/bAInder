{
  "name": "bainder",
  "version": "1.0.0",
  "description": "Chrome extension to organize AI browser chats (ChatGPT, Claude, Gemini) into a hierarchical notebook with topics, table of contents, and search functionality.",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "keywords": [
    "chrome-extension",
    "ai",
    "chat",
    "organizer",
    "notebook"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/press-start-2p": "^5.2.7",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.6.2",
    "jsdom": "^28.1.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
