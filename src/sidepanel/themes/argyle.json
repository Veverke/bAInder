{
  "$schema": "./spec.schema.json",
  "name": "Argyle",
  "id": "argyle",
  "version": "1.0",
  "author": "bAInder",
  "description": "Soft blush with a classic g127-inspired three-layer argyle diamond pattern.",
  "category": "pattern",
  "dark": false,
  "variables": {
    "--primary":           "#c47a72",
    "--primary-hover":     "#d48e86",
    "--primary-light":     "rgba(196,122,114,0.10)",
    "--primary-dark":      "#a05f58",

    "--header-bg":         "linear-gradient(135deg, #4a1c1a 0%, #6b2820 100%)",
    "--header-accent":     "#e8a898",

    "--bg-primary":        "#faf4f0",
    "--bg-secondary":      "#f2e8e2",
    "--bg-tertiary":       "#e8dcd4",
    "--bg-elevated":       "#ffffff",
    "--bg-hover":          "rgba(196,122,114,0.06)",
    "--bg-active":         "rgba(196,122,114,0.12)",

    "--border-primary":    "#e0cec8",
    "--border-secondary":  "#ccb8b0",
    "--border-focus":      "#c47a72",

    "--text-primary":      "#2a1612",
    "--text-secondary":    "#5a3430",
    "--text-tertiary":     "#9a7870",
    "--text-inverse":      "#ffffff",

    "--success":           "#4a7a4a",
    "--success-bg":        "rgba(74,122,74,0.10)",
    "--warning":           "#a07030",
    "--warning-bg":        "rgba(160,112,48,0.10)",
    "--danger":            "#c04040",
    "--danger-bg":         "rgba(192,64,64,0.10)",
    "--info":              "#5a7aaa",
    "--info-bg":           "rgba(90,122,170,0.10)",

    "--shadow-sm":         "0 1px 2px rgba(42,22,18,0.08)",
    "--shadow-md":         "0 4px 10px rgba(42,22,18,0.10)",
    "--shadow-lg":         "0 8px 22px rgba(42,22,18,0.12)",
    "--shadow-xl":         "0 16px 38px rgba(42,22,18,0.15)",

    "--overlay":           "rgba(42,22,18,0.50)",
    "--overlay-light":     "rgba(42,22,18,0.10)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "6px",
    "--radius-lg":         "10px",
    "--radius-xl":         "14px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #c47a72 0%, #e8a898 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #e8a898 0%, #c47a72 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #faf4f0 0%, #f5ece6 100%)",
    "--gradient-header":   "linear-gradient(90deg, #4a1c1a 0%, #6b2820 100%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(250,244,240,0.85)",

    "--page-bg":           "#faf4f0",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-normal": "200ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-slow":   "360ms cubic-bezier(0.4,0,0.2,1)",
    "--easing-standard":   "cubic-bezier(0.4,0,0.2,1)",
    "--easing-decelerate": "cubic-bezier(0,0,0.2,1)",
    "--easing-accelerate": "cubic-bezier(0.4,0,1,1)",

    "--focus-ring-color":  "#c47a72",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.06em",

    "--code-bg":           "#f0e4e0",
    "--code-text":         "#2a1612",
    "--code-keyword":      "#c47a72",
    "--code-string":       "#4a7a4a",
    "--code-comment":      "#9a7870",
    "--code-number":       "#c04040",
    "--code-operator":     "#5a7aaa",

    "--selection-bg":      "rgba(196,122,114,0.20)",
    "--selection-text":    "#2a1612",

    "--scrollbar-thumb":   "#ccb8b0",
    "--scrollbar-track":   "#faf4f0",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#c47a72",
    "--icon-secondary":    "#d48e86",
    "--icon-muted":        "#9a7870",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(-45deg, transparent 48%, rgba(196,122,114,0.14) 0 52%, transparent 0), linear-gradient(45deg, transparent 48%, rgba(196,122,114,0.14) 0 52%, transparent 0), repeating-conic-gradient(from 45deg, rgba(196,122,114,0.06) 0 25%, rgba(196,122,114,0.03) 0 50%)",
    "--pattern-size":      "80px 80px",
    "--pattern-header":    "linear-gradient(-45deg, transparent 48%, rgba(232,168,152,0.22) 0 52%, transparent 0), linear-gradient(45deg, transparent 48%, rgba(232,168,152,0.22) 0 52%, transparent 0), repeating-conic-gradient(from 45deg, rgba(232,168,152,0.10) 0 25%, rgba(232,168,152,0.05) 0 50%)",

    "--card-accent-border": "3px solid #c47a72"
  }
}
