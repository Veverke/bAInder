{
  "$schema": "./spec.schema.json",
  "name": "Blueprint",
  "id": "blueprint",
  "version": "1.0",
  "author": "bAInder",
  "description": "Engineering dark-blue with a precision cyan dot-grid pattern.",
  "category": "solid",
  "dark": true,
  "variables": {
    "--primary":           "#38bdf8",
    "--primary-hover":     "#7dd3fc",
    "--primary-light":     "rgba(56,189,248,0.15)",
    "--primary-dark":      "#0ea5e9",

    "--header-bg":         "#020b14",
    "--header-accent":     "#38bdf8",

    "--bg-primary":        "#020913",
    "--bg-secondary":      "#051525",
    "--bg-tertiary":       "#071c30",
    "--bg-elevated":       "#0a2240",
    "--bg-hover":          "rgba(56,189,248,0.08)",
    "--bg-active":         "rgba(56,189,248,0.15)",

    "--border-primary":    "#0d2d44",
    "--border-secondary":  "#1a4a68",
    "--border-focus":      "#38bdf8",

    "--text-primary":      "#bae6fd",
    "--text-secondary":    "#7dd3fc",
    "--text-tertiary":     "#38688a",
    "--text-inverse":      "#020913",

    "--success":           "#34d399",
    "--success-bg":        "rgba(52,211,153,0.12)",
    "--warning":           "#fbbf24",
    "--warning-bg":        "rgba(251,191,36,0.12)",
    "--danger":            "#f87171",
    "--danger-bg":         "rgba(248,113,113,0.12)",
    "--info":              "#60a5fa",
    "--info-bg":           "rgba(96,165,250,0.12)",

    "--shadow-sm":         "0 0 0 1px rgba(56,189,248,0.12)",
    "--shadow-md":         "0 0 16px rgba(56,189,248,0.14)",
    "--shadow-lg":         "0 0 32px rgba(56,189,248,0.18)",
    "--shadow-xl":         "0 0 56px rgba(56,189,248,0.22)",

    "--overlay":           "rgba(2,9,19,0.90)",
    "--overlay-light":     "rgba(56,189,248,0.06)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "3px",
    "--radius-md":         "4px",
    "--radius-lg":         "6px",
    "--radius-xl":         "8px",
    "--radius-full":       "4px",

    "--gradient-primary":  "linear-gradient(135deg, #38bdf8 0%, #818cf8 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #38bdf8 0%, #34d399 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #020913 0%, #030e1c 100%)",
    "--gradient-header":   "linear-gradient(90deg, #020b14 0%, #040e1e 100%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(2,9,19,0.72)",

    "--page-bg":           "#020913",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-normal": "200ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-slow":   "360ms cubic-bezier(0.4,0,0.2,1)",
    "--easing-standard":   "cubic-bezier(0.4,0,0.2,1)",
    "--easing-decelerate": "cubic-bezier(0,0,0.2,1)",
    "--easing-accelerate": "cubic-bezier(0.4,0,1,1)",

    "--focus-ring-color":  "#38bdf8",
    "--focus-ring-width":  "1px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.06em",

    "--code-bg":           "#010711",
    "--code-text":         "#bae6fd",
    "--code-keyword":      "#38bdf8",
    "--code-string":       "#86efac",
    "--code-comment":      "#2a5a7a",
    "--code-number":       "#fb923c",
    "--code-operator":     "#7dd3fc",

    "--selection-bg":      "rgba(56,189,248,0.25)",
    "--selection-text":    "#bae6fd",

    "--scrollbar-thumb":   "#1a4a68",
    "--scrollbar-track":   "#020913",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#38bdf8",
    "--icon-secondary":    "#7dd3fc",
    "--icon-muted":        "#38688a",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "none",
    "--pattern-size":      "auto",
    "--pattern-header":    "none",

    "--text-glow": "0 0 5px rgba(56,189,248,0.5)",
    "--glow-primary": "0 0 10px #38bdf8, 0 0 18px rgba(56,189,248,0.28)",
    "--card-accent-border": "3px solid #38bdf8",
    "--btn-text-transform": "uppercase",
    "--btn-letter-spacing": "0.08em",
    "--animation-click": "theme-burst 0.18s ease-out",
    "--animation-hover": "theme-glow-pulse 0.6s ease"
  }
}
