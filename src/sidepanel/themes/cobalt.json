{
  "$schema": "./spec.schema.json",
  "name": "Cobalt",
  "id": "cobalt",
  "version": "1.0",
  "author": "bAInder",
  "description": "Deep ocean-cobalt frosted glass with electric sapphire accents.",
  "category": "blur",
  "dark": true,
  "variables": {
    "--primary":           "#38bdf8",
    "--primary-hover":     "#7dd3fc",
    "--primary-light":     "rgba(56, 189, 248, 0.15)",
    "--primary-dark":      "#0ea5e9",

    "--header-bg":         "rgba(3, 11, 26, 0.65)",
    "--header-accent":     "#38bdf8",

    "--bg-primary":        "rgba(3, 11, 26, 0.65)",
    "--bg-secondary":      "rgba(7, 18, 40, 0.55)",
    "--bg-tertiary":       "rgba(12, 28, 58, 0.45)",
    "--bg-elevated":       "rgba(7, 18, 40, 0.75)",
    "--bg-hover":          "rgba(56, 189, 248, 0.08)",
    "--bg-active":         "rgba(56, 189, 248, 0.15)",

    "--border-primary":    "rgba(56, 189, 248, 0.18)",
    "--border-secondary":  "rgba(56, 189, 248, 0.32)",
    "--border-focus":      "#38bdf8",

    "--text-primary":      "#e0f2fe",
    "--text-secondary":    "#7dd3fc",
    "--text-tertiary":     "#1d4ed8",
    "--text-inverse":      "#030b1a",

    "--success":           "#34d399",
    "--success-bg":        "rgba(52, 211, 153, 0.12)",
    "--warning":           "#fbbf24",
    "--warning-bg":        "rgba(251, 191, 36, 0.12)",
    "--danger":            "#f87171",
    "--danger-bg":         "rgba(248, 113, 113, 0.12)",
    "--info":              "#818cf8",
    "--info-bg":           "rgba(129, 140, 248, 0.12)",

    "--shadow-sm":         "0 2px 8px rgba(14, 165, 233, 0.18)",
    "--shadow-md":         "0 4px 20px rgba(14, 165, 233, 0.26)",
    "--shadow-lg":         "0 8px 40px rgba(14, 165, 233, 0.32)",
    "--shadow-xl":         "0 16px 64px rgba(14, 165, 233, 0.40)",

    "--overlay":           "rgba(0, 5, 18, 0.82)",
    "--overlay-light":     "rgba(56, 189, 248, 0.06)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "8px",
    "--radius-lg":         "12px",
    "--radius-xl":         "18px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #38bdf8 0%, #818cf8 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #38bdf8 0%, #34d399 100%)",
    "--gradient-bg":       "linear-gradient(135deg, #030b1a 0%, #071830 45%, #0b1e42 75%, #030b1a 100%)",
    "--gradient-header":   "linear-gradient(90deg, rgba(3,11,26,0.70) 0%, rgba(7,18,40,0.65) 100%)",

    "--blur-sm":           "blur(8px)",
    "--blur-md":           "blur(18px)",
    "--blur-lg":           "blur(36px)",
    "--glass-bg":          "rgba(3, 11, 26, 0.58)",

    "--page-bg":           "linear-gradient(135deg, #030b1a 0%, #071830 45%, #0b1e42 75%, #030b1a 100%)",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-normal": "200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-slow":   "360ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0.4, 0, 1, 1)",

    "--focus-ring-color":  "#38bdf8",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.04em",

    "--code-bg":           "rgba(2, 8, 20, 0.82)",
    "--code-text":         "#e0f2fe",
    "--code-keyword":      "#38bdf8",
    "--code-string":       "#34d399",
    "--code-comment":      "#1d4ed8",
    "--code-number":       "#fbbf24",
    "--code-operator":     "#818cf8",

    "--selection-bg":      "rgba(56, 189, 248, 0.25)",
    "--selection-text":    "#e0f2fe",

    "--scrollbar-thumb":   "rgba(56, 189, 248, 0.35)",
    "--scrollbar-track":   "rgba(3, 11, 26, 0.60)",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#38bdf8",
    "--icon-secondary":    "#7dd3fc",
    "--icon-muted":        "#1d4ed8",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(135deg, #030b1a 0%, #071830 45%, #0b1e42 75%, #030b1a 100%)",
    "--pattern-size":      "auto",
    "--pattern-header":    "linear-gradient(90deg, #030b1a 0%, #071830 100%)",

    "--text-glow": "0 0 6px rgba(56,189,248,0.55)",
    "--glow-primary": "0 0 12px #38bdf8, 0 0 22px rgba(56,189,248,0.32)",
    "--card-accent-border": "3px solid #38bdf8",
    "--btn-text-transform": "uppercase",
    "--btn-letter-spacing": "0.06em",
    "--animation-click": "theme-burst 0.18s ease-out",
    "--animation-hover": "theme-glow-pulse 0.6s ease"
  }
}
