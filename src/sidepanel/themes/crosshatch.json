{
  "$schema": "./spec.schema.json",
  "name": "Crosshatch",
  "id": "crosshatch",
  "version": "1.0",
  "author": "bAInder",
  "description": "Cool blue-slate with fine g99-inspired diamond crosshatch lines.",
  "category": "pattern",
  "dark": false,
  "variables": {
    "--primary":           "#4a6fa5",
    "--primary-hover":     "#5a80b8",
    "--primary-light":     "rgba(74,111,165,0.10)",
    "--primary-dark":      "#3a5a90",

    "--header-bg":         "linear-gradient(135deg, #1a2a40 0%, #243348 100%)",
    "--header-accent":     "#88abc2",

    "--bg-primary":        "#f0f4f8",
    "--bg-secondary":      "#e4ebf2",
    "--bg-tertiary":       "#d4dde8",
    "--bg-elevated":       "#ffffff",
    "--bg-hover":          "rgba(74,111,165,0.06)",
    "--bg-active":         "rgba(74,111,165,0.12)",

    "--border-primary":    "#c8d4e0",
    "--border-secondary":  "#b0c0d0",
    "--border-focus":      "#4a6fa5",

    "--text-primary":      "#1a2535",
    "--text-secondary":    "#3a4a60",
    "--text-tertiary":     "#7a8fa4",
    "--text-inverse":      "#ffffff",

    "--success":           "#2a7a4a",
    "--success-bg":        "rgba(42,122,74,0.10)",
    "--warning":           "#8a6020",
    "--warning-bg":        "rgba(138,96,32,0.10)",
    "--danger":            "#b03030",
    "--danger-bg":         "rgba(176,48,48,0.10)",
    "--info":              "#4a6fa5",
    "--info-bg":           "rgba(74,111,165,0.10)",

    "--shadow-sm":         "0 1px 2px rgba(26,37,53,0.07)",
    "--shadow-md":         "0 4px 10px rgba(26,37,53,0.09)",
    "--shadow-lg":         "0 8px 22px rgba(26,37,53,0.11)",
    "--shadow-xl":         "0 16px 38px rgba(26,37,53,0.14)",

    "--overlay":           "rgba(26,37,53,0.50)",
    "--overlay-light":     "rgba(26,37,53,0.10)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "6px",
    "--radius-lg":         "10px",
    "--radius-xl":         "14px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #4a6fa5 0%, #7090c0 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #88abc2 0%, #4a6fa5 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #f0f4f8 0%, #e8eef4 100%)",
    "--gradient-header":   "linear-gradient(90deg, #1a2a40 0%, #243348 100%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(240,244,248,0.85)",

    "--page-bg":           "#f0f4f8",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-normal": "200ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-slow":   "360ms cubic-bezier(0.4,0,0.2,1)",
    "--easing-standard":   "cubic-bezier(0.4,0,0.2,1)",
    "--easing-decelerate": "cubic-bezier(0,0,0.2,1)",
    "--easing-accelerate": "cubic-bezier(0.4,0,1,1)",

    "--focus-ring-color":  "#4a6fa5",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.06em",

    "--code-bg":           "#e0e8f0",
    "--code-text":         "#1a2535",
    "--code-keyword":      "#4a6fa5",
    "--code-string":       "#2a7a4a",
    "--code-comment":      "#7a8fa4",
    "--code-number":       "#b03030",
    "--code-operator":     "#4a6fa5",

    "--selection-bg":      "rgba(74,111,165,0.20)",
    "--selection-text":    "#1a2535",

    "--scrollbar-thumb":   "#b0c0d0",
    "--scrollbar-track":   "#f0f4f8",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#4a6fa5",
    "--icon-secondary":    "#7090c0",
    "--icon-muted":        "#7a8fa4",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(45deg, transparent 45%, rgba(74,111,165,0.20) 46% 54%, transparent 55%), linear-gradient(-45deg, transparent 45%, rgba(74,111,165,0.20) 46% 54%, transparent 55%)",
    "--pattern-size":      "60px 60px",
    "--pattern-header":    "linear-gradient(45deg, transparent 45%, rgba(136,171,194,0.28) 46% 54%, transparent 55%), linear-gradient(-45deg, transparent 45%, rgba(136,171,194,0.28) 46% 54%, transparent 55%)",

    "--card-accent-border": "3px solid #4a6fa5"
  }
}
