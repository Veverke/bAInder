{
  "$schema": "./spec.schema.json",
  "name": "Crystal",
  "id": "crystal",
  "version": "1.0",
  "author": "bAInder",
  "description": "Deep indigo frosted crystal with violet and sapphire luminescence.",
  "category": "blur",
  "dark": true,
  "variables": {
    "--primary":           "#818cf8",
    "--primary-hover":     "#a5b4fc",
    "--primary-light":     "rgba(129, 140, 248, 0.15)",
    "--primary-dark":      "#6366f1",

    "--header-bg":         "rgba(30, 27, 75, 0.65)",
    "--header-accent":     "#818cf8",

    "--bg-primary":        "rgba(30, 27, 75, 0.65)",
    "--bg-secondary":      "rgba(49, 46, 129, 0.50)",
    "--bg-tertiary":       "rgba(67, 56, 202, 0.35)",
    "--bg-elevated":       "rgba(49, 46, 129, 0.72)",
    "--bg-hover":          "rgba(129, 140, 248, 0.08)",
    "--bg-active":         "rgba(129, 140, 248, 0.16)",

    "--border-primary":    "rgba(129, 140, 248, 0.20)",
    "--border-secondary":  "rgba(129, 140, 248, 0.35)",
    "--border-focus":      "#818cf8",

    "--text-primary":      "#e0e7ff",
    "--text-secondary":    "#a5b4fc",
    "--text-tertiary":     "#6366f1",
    "--text-inverse":      "#1e1b4b",

    "--success":           "#34d399",
    "--success-bg":        "rgba(52, 211, 153, 0.12)",
    "--warning":           "#fbbf24",
    "--warning-bg":        "rgba(251, 191, 36, 0.12)",
    "--danger":            "#f87171",
    "--danger-bg":         "rgba(248, 113, 113, 0.12)",
    "--info":              "#38bdf8",
    "--info-bg":           "rgba(56, 189, 248, 0.12)",

    "--shadow-sm":         "0 2px 8px rgba(99, 102, 241, 0.18)",
    "--shadow-md":         "0 4px 20px rgba(99, 102, 241, 0.24)",
    "--shadow-lg":         "0 8px 40px rgba(99, 102, 241, 0.30)",
    "--shadow-xl":         "0 16px 64px rgba(99, 102, 241, 0.36)",

    "--overlay":           "rgba(15, 10, 60, 0.80)",
    "--overlay-light":     "rgba(129, 140, 248, 0.06)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "8px",
    "--radius-lg":         "12px",
    "--radius-xl":         "18px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #818cf8 0%, #38bdf8 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #a78bfa 0%, #818cf8 100%)",
    "--gradient-bg":       "linear-gradient(135deg, #1e1b4b 0%, #312e81 40%, #0f172a 100%)",
    "--gradient-header":   "linear-gradient(90deg, rgba(30,27,75,0.70) 0%, rgba(49,46,129,0.65) 100%)",

    "--blur-sm":           "blur(8px)",
    "--blur-md":           "blur(18px)",
    "--blur-lg":           "blur(36px)",
    "--glass-bg":          "rgba(30, 27, 75, 0.58)",

    "--page-bg":           "linear-gradient(135deg, #1e1b4b 0%, #312e81 40%, #0f172a 100%)",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-normal": "200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-slow":   "360ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0.4, 0, 1, 1)",

    "--focus-ring-color":  "#818cf8",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.04em",

    "--code-bg":           "rgba(15, 12, 60, 0.80)",
    "--code-text":         "#e0e7ff",
    "--code-keyword":      "#818cf8",
    "--code-string":       "#34d399",
    "--code-comment":      "#6366f1",
    "--code-number":       "#fbbf24",
    "--code-operator":     "#38bdf8",

    "--selection-bg":      "rgba(129, 140, 248, 0.25)",
    "--selection-text":    "#e0e7ff",

    "--scrollbar-thumb":   "rgba(129, 140, 248, 0.35)",
    "--scrollbar-track":   "rgba(30, 27, 75, 0.55)",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#818cf8",
    "--icon-secondary":    "#a5b4fc",
    "--icon-muted":        "#6366f1",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(135deg, #1e1b4b 0%, #312e81 40%, #0f172a 100%)",
    "--pattern-size":      "auto",
    "--pattern-header":    "linear-gradient(90deg, #1e1b4b 0%, #312e81 100%)",

    "--card-accent-border": "2px solid #818cf8",
    "--btn-letter-spacing": "0.02em"
  }
}
