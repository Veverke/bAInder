{
  "$schema": "./spec.schema.json",
  "name": "Dark",
  "id": "dark",
  "version": "1.0",
  "author": "bAInder",
  "description": "Deep slate dark theme with soft indigo accents.",
  "category": "solid",
  "dark": true,
  "variables": {
    "--primary":           "#818cf8",
    "--primary-hover":     "#a5b4fc",
    "--primary-light":     "#312e81",
    "--primary-dark":      "#c7d2fe",

    "--header-bg":         "linear-gradient(135deg, #1a1c35 0%, #0f172a 55%)",
    "--header-accent":     "#818cf8",

    "--bg-primary":        "#0f172a",
    "--bg-secondary":      "#1e293b",
    "--bg-tertiary":       "#334155",
    "--bg-elevated":       "#1e293b",
    "--bg-hover":          "#334155",
    "--bg-active":         "#475569",

    "--border-primary":    "#334155",
    "--border-secondary":  "#475569",
    "--border-focus":      "#818cf8",

    "--text-primary":      "#f1f5f9",
    "--text-secondary":    "#cbd5e1",
    "--text-tertiary":     "#64748b",
    "--text-inverse":      "#0f172a",

    "--success":           "#34d399",
    "--success-bg":        "#064e3b",
    "--warning":           "#fbbf24",
    "--warning-bg":        "#78350f",
    "--danger":            "#f87171",
    "--danger-bg":         "#7f1d1d",
    "--info":              "#60a5fa",
    "--info-bg":           "#1e3a8a",

    "--shadow-sm":         "0 1px 2px 0 rgba(0, 0, 0, 0.3)",
    "--shadow-md":         "0 4px 6px -1px rgba(0, 0, 0, 0.4), 0 2px 4px -1px rgba(0, 0, 0, 0.3)",
    "--shadow-lg":         "0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -2px rgba(0, 0, 0, 0.4)",
    "--shadow-xl":         "0 20px 25px -5px rgba(0, 0, 0, 0.6), 0 10px 10px -5px rgba(0, 0, 0, 0.5)",

    "--overlay":           "rgba(0, 0, 0, 0.7)",
    "--overlay-light":     "rgba(0, 0, 0, 0.2)",

    "--gradient-primary":  "linear-gradient(135deg, #818cf8 0%, #a78bfa 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #818cf8 0%, #60a5fa 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #0f172a 0%, #1e293b 100%)",
    "--gradient-header":   "linear-gradient(135deg, #1a1c35 0%, #0f172a 55%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(30, 41, 59, 0.7)",

    "--page-bg":           "#0f172a",
    "--noise-opacity":     "0",

    "--transition-fast":   "150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-normal": "250ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-slow":   "400ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0.4, 0, 1, 1)",

    "--focus-ring-color":  "#818cf8",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.5",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.05em",

    "--code-bg":           "#1e293b",
    "--code-text":         "#f1f5f9",
    "--code-keyword":      "#a78bfa",
    "--code-string":       "#34d399",
    "--code-comment":      "#64748b",
    "--code-number":       "#f87171",
    "--code-operator":     "#60a5fa",

    "--selection-bg":      "#312e81",
    "--selection-text":    "#f1f5f9",

    "--scrollbar-thumb":   "#475569",
    "--scrollbar-track":   "#1e293b",
    "--scrollbar-width":   "8px",

    "--icon-primary":      "#818cf8",
    "--icon-secondary":    "#cbd5e1",
    "--icon-muted":        "#64748b",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "none",
    "--pattern-size":      "auto",
    "--pattern-header":    "none",

    "--cursor-default":    "auto",
    "--cursor-pointer":    "pointer",
    "--theme-icon-accent": "'\ud83c\udfa8'",

    "--font-display":      "inherit",
    "--text-glow":         "none",
    "--image-filter":      "none",
    "--btn-text-transform":"none",
    "--btn-letter-spacing":"0",
    "--animation-click":   "none",
    "--animation-hover":   "none",
    "--glow-primary":      "none",

    "--bg-image":          "none",
    "--bg-image-opacity":  "0",
    "--bg-image-blur":     "0px",
    "--bg-image-size":     "cover",
    "--bg-image-position": "center"
  }
}
