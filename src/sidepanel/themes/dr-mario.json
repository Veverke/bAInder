{
  "$schema": "./spec.schema.json",
  "name": "Dr. Mario",
  "id": "dr-mario",
  "version": "1.0",
  "author": "bAInder",
  "description": "Vitamin Vaccination — Press Start 2P NES pixel type, pill-bottle grid, red/blue/yellow capsule palette and virus-zapping glow.",
  "category": "videogame",
  "dark": true,
  "dependencies": { "fonts": ["Press Start 2P"] },
  "variables": {
    "--primary":           "#e03030",
    "--primary-hover":     "#ff4444",
    "--primary-light":     "rgba(224,48,48,0.18)",
    "--primary-dark":      "#aa1a1a",

    "--header-bg":         "linear-gradient(180deg, #0c1030 0%, #06105a 100%)",
    "--header-accent":     "#e8cc00",

    "--bg-primary":        "rgba(6,12,32,0.55)",
    "--bg-secondary":      "rgba(10,20,48,0.60)",
    "--bg-tertiary":       "rgba(14,28,64,0.65)",
    "--bg-elevated":       "rgba(18,36,78,0.62)",
    "--bg-hover":          "rgba(224,48,48,0.11)",
    "--bg-active":         "rgba(224,48,48,0.22)",

    "--border-primary":    "rgba(255,255,255,0.12)",
    "--border-secondary":  "rgba(255,255,255,0.24)",
    "--border-focus":      "#e8cc00",

    "--text-primary":      "#ffffff",
    "--text-secondary":    "#e8cc00",
    "--text-tertiary":     "#4466cc",
    "--text-inverse":      "#060c20",

    "--success":           "#44dd44",
    "--success-bg":        "rgba(68,221,68,0.14)",
    "--warning":           "#e8cc00",
    "--warning-bg":        "rgba(232,204,0,0.14)",
    "--danger":            "#e03030",
    "--danger-bg":         "rgba(224,48,48,0.14)",
    "--info":              "#3366ff",
    "--info-bg":           "rgba(51,102,255,0.14)",

    "--shadow-sm":         "3px 3px 0 #000000",
    "--shadow-md":         "4px 4px 0 #000000, 0 6px 18px rgba(0,0,0,0.60)",
    "--shadow-lg":         "6px 6px 0 #000000, 0 10px 30px rgba(0,0,0,0.70)",
    "--shadow-xl":         "8px 8px 0 #000000, 0 16px 44px rgba(0,0,0,0.80)",

    "--overlay":           "rgba(6,12,32,0.92)",
    "--overlay-light":     "rgba(232,204,0,0.08)",

    "--font-sans":         "'Press Start 2P', 'Courier New', monospace",
    "--font-mono":         "'Press Start 2P', 'Courier New', monospace",
    "--font-serif":        "'Press Start 2P', 'Courier New', monospace",

    "--radius-xs":         "10px",
    "--radius-sm":         "18px",
    "--radius-md":         "28px",
    "--radius-lg":         "40px",
    "--radius-xl":         "56px",
    "--radius-full":       "999px",

    "--pattern-bg":        "linear-gradient(rgba(255,255,255,0.07) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.07) 1px, transparent 1px)",
    "--pattern-size":      "32px 32px",
    "--pattern-header":    "repeating-linear-gradient(90deg, rgba(224,48,48,0.30) 0px 10px, transparent 10px 20px, rgba(51,102,255,0.30) 20px 30px, transparent 30px 40px, rgba(232,204,0,0.30) 40px 50px, transparent 50px 60px)",

    "--gradient-primary":  "linear-gradient(135deg, #e03030 0%, #3366ff 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #e8cc00 0%, #e03030 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #060c20 0%, #0a1430 100%)",
    "--gradient-header":   "linear-gradient(180deg, #0c1030 0%, #06105a 100%)",

    "--blur-sm":           "blur(0px)",
    "--blur-md":           "blur(0px)",
    "--blur-lg":           "blur(0px)",
    "--glass-bg":          "rgba(0,0,0,0)",

    "--page-bg":           "linear-gradient(180deg, #060c20 0%, #0a1430 100%)",
    "--noise-opacity":     "0",

    "--transition-fast":   "0ms",
    "--transition-normal": "0ms",
    "--transition-slow":   "0ms",
    "--easing-standard":   "step-end",
    "--easing-decelerate": "step-end",
    "--easing-accelerate": "step-end",

    "--focus-ring-color":  "#e8cc00",
    "--focus-ring-width":  "3px",
    "--focus-ring-offset": "0px",
    "--focus-ring-style":  "solid",

    "--code-bg":           "rgba(6,12,32,0.92)",
    "--code-text":         "#ffffff",
    "--code-keyword":      "#e03030",
    "--code-string":       "#44dd44",
    "--code-comment":      "#4466cc",
    "--code-number":       "#e8cc00",
    "--code-operator":     "#3366ff",

    "--selection-bg":      "rgba(232,204,0,0.30)",
    "--selection-text":    "#060c20",

    "--scrollbar-thumb":   "#e03030",
    "--scrollbar-track":   "#0a1430",
    "--scrollbar-width":   "8px",

    "--icon-primary":      "#e8cc00",
    "--icon-secondary":    "#e03030",
    "--icon-muted":        "#4466cc",

    "--font-display":             "'Press Start 2P', 'Courier New', monospace",
    "--text-glow":                "2px 2px 0 #000000, 0 0 10px rgba(232,204,0,0.55)",
    "--image-filter":             "saturate(1.30) contrast(1.10)",
    "--card-accent-border":       "4px solid #e03030",
    "--btn-text-transform":       "uppercase",
    "--btn-letter-spacing":       "0.06em",
    "--animation-click":          "theme-burst 0.18s ease-out",
    "--animation-hover":          "none",
    "--glow-primary":             "0 0 14px rgba(224,48,48,0.70)",

    "--bg-image":          "url('https://m.media-amazon.com/images/M/MV5BODIyMzdlYzktMjBjMS00NWUyLWJlZWMtMDIyMWQ5MDZiODUwXkEyXkFqcGc@._V1_.jpg')",
    "--bg-image-opacity":  "0.55",
    "--bg-image-blur":     "0px",
    "--bg-image-size":     "cover",
    "--bg-image-position": "center"
  }
}
