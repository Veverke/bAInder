{
  "$schema": "./spec.schema.json",
  "name": "Ember Glow",
  "id": "ember",
  "version": "1.0",
  "author": "bAInder",
  "description": "Near-black charcoal warming through deep mahogany to a smouldering amber core.",
  "category": "gradient",
  "dark": true,
  "variables": {
    "--primary":           "#e86030",
    "--primary-hover":     "#f07848",
    "--primary-light":     "rgba(232,96,48,0.15)",
    "--primary-dark":      "#c04818",

    "--header-bg":         "#0a0806",
    "--header-accent":     "#e86030",

    "--bg-primary":        "#0a0806",
    "--bg-secondary":      "#160e08",
    "--bg-tertiary":       "#201408",
    "--bg-elevated":       "#2a1c0a",
    "--bg-hover":          "rgba(232,96,48,0.08)",
    "--bg-active":         "rgba(232,96,48,0.15)",

    "--border-primary":    "#3a2010",
    "--border-secondary":  "rgba(232,96,48,0.28)",
    "--border-focus":      "#e86030",

    "--text-primary":      "#f8dcc8",
    "--text-secondary":    "#d89878",
    "--text-tertiary":     "#806040",
    "--text-inverse":      "#0a0806",

    "--success":           "#80c060",
    "--success-bg":        "rgba(128,192,96,0.12)",
    "--warning":           "#f0c040",
    "--warning-bg":        "rgba(240,192,64,0.12)",
    "--danger":            "#f04040",
    "--danger-bg":         "rgba(240,64,64,0.12)",
    "--info":              "#60a0d8",
    "--info-bg":           "rgba(96,160,216,0.12)",

    "--shadow-sm":         "0 0 8px rgba(232,96,48,0.12)",
    "--shadow-md":         "0 0 20px rgba(232,96,48,0.16)",
    "--shadow-lg":         "0 0 36px rgba(232,96,48,0.20)",
    "--shadow-xl":         "0 0 56px rgba(232,96,48,0.24)",

    "--overlay":           "rgba(10,8,6,0.90)",
    "--overlay-light":     "rgba(232,96,48,0.06)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "6px",
    "--radius-lg":         "10px",
    "--radius-xl":         "14px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #e86030 0%, #f0c040 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #f0c040 0%, #e86030 100%)",
    "--gradient-bg":       "linear-gradient(160deg, #0a0806 0%, #1e0e08 40%, #3a1808 70%, #0a0806 100%)",
    "--gradient-header":   "linear-gradient(90deg, #0a0806 0%, #1e0e08 100%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(10,8,6,0.72)",

    "--page-bg":           "linear-gradient(160deg, #0a0806 0%, #1e0e08 40%, #3a1808 70%, #0a0806 100%)",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-normal": "200ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-slow":   "360ms cubic-bezier(0.4,0,0.2,1)",
    "--easing-standard":   "cubic-bezier(0.4,0,0.2,1)",
    "--easing-decelerate": "cubic-bezier(0,0,0.2,1)",
    "--easing-accelerate": "cubic-bezier(0.4,0,1,1)",

    "--focus-ring-color":  "#e86030",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.06em",

    "--code-bg":           "#080604",
    "--code-text":         "#f8dcc8",
    "--code-keyword":      "#e86030",
    "--code-string":       "#80c060",
    "--code-comment":      "#806040",
    "--code-number":       "#f0c040",
    "--code-operator":     "#60a0d8",

    "--selection-bg":      "rgba(232,96,48,0.25)",
    "--selection-text":    "#f8dcc8",

    "--scrollbar-thumb":   "#3a2010",
    "--scrollbar-track":   "#0a0806",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#e86030",
    "--icon-secondary":    "#f07848",
    "--icon-muted":        "#806040",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(160deg, #0a0806 0%, #1e0e08 40%, #3a1808 70%, #0a0806 100%)",
    "--pattern-size":      "auto",
    "--pattern-header":    "linear-gradient(90deg, #0a0806 0%, #1e0e08 100%)",

    "--text-glow": "0 0 8px rgba(232,96,48,0.6)",
    "--glow-primary": "0 0 12px #e86030, 0 0 22px rgba(232,96,48,0.35)",
    "--card-accent-border": "4px solid #e86030",
    "--btn-letter-spacing": "0.04em",
    "--animation-click": "theme-burst 0.18s ease-out",
    "--animation-hover": "theme-glow-pulse 0.5s ease"
  }
}
