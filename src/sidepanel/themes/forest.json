{
  "$schema": "./spec.schema.json",
  "name": "Forest",
  "id": "forest",
  "version": "1.0",
  "author": "bAInder",
  "description": "Deep woodland greens with warm amber accents.",
  "category": "solid",
  "dark": true,
  "variables": {
    "--primary":           "#7cb87c",
    "--primary-hover":     "#8fca8f",
    "--primary-light":     "rgba(124, 184, 124, 0.15)",
    "--primary-dark":      "#568f56",

    "--header-bg":         "#0e1a0e",
    "--header-accent":     "#a8d5a2",

    "--bg-primary":        "#0e1a0e",
    "--bg-secondary":      "#162416",
    "--bg-tertiary":       "#1c2d1c",
    "--bg-elevated":       "#213521",
    "--bg-hover":          "rgba(124, 184, 124, 0.08)",
    "--bg-active":         "rgba(124, 184, 124, 0.16)",

    "--border-primary":    "#243824",
    "--border-secondary":  "#365536",
    "--border-focus":      "#7cb87c",

    "--text-primary":      "#d4ecd4",
    "--text-secondary":    "#a8c8a8",
    "--text-tertiary":     "#6d966d",
    "--text-inverse":      "#0e1a0e",

    "--success":           "#a8d5a2",
    "--success-bg":        "rgba(168, 213, 162, 0.12)",
    "--warning":           "#d4a640",
    "--warning-bg":        "rgba(212, 166, 64, 0.12)",
    "--danger":            "#cc6666",
    "--danger-bg":         "rgba(204, 102, 102, 0.12)",
    "--info":              "#6baed6",
    "--info-bg":           "rgba(107, 174, 214, 0.12)",

    "--shadow-sm":         "0 1px 4px rgba(0, 0, 0, 0.30)",
    "--shadow-md":         "0 4px 16px rgba(0, 0, 0, 0.35)",
    "--shadow-lg":         "0 8px 28px rgba(0, 0, 0, 0.40)",
    "--shadow-xl":         "0 16px 44px rgba(0, 0, 0, 0.45)",

    "--overlay":           "rgba(14, 26, 14, 0.92)",
    "--overlay-light":     "rgba(124, 184, 124, 0.05)",

    "--gradient-primary":  "linear-gradient(135deg, #7cb87c 0%, #d4a640 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #a8d5a2 0%, #d4a640 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #0e1a0e 0%, #162416 100%)",
    "--gradient-header":   "linear-gradient(135deg, #0e1a0e 0%, #162416 100%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(14, 26, 14, 0.7)",

    "--page-bg":           "#0e1a0e",
    "--noise-opacity":     "0",

    "--transition-fast":   "150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-normal": "250ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-slow":   "400ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0.4, 0, 1, 1)",

    "--focus-ring-color":  "#7cb87c",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.5",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.05em",

    "--code-bg":           "#162416",
    "--code-text":         "#d4ecd4",
    "--code-keyword":      "#a8d5a2",
    "--code-string":       "#7cb87c",
    "--code-comment":      "#6d966d",
    "--code-number":       "#d4a640",
    "--code-operator":     "#cc6666",

    "--selection-bg":      "rgba(124, 184, 124, 0.3)",
    "--selection-text":    "#d4ecd4",

    "--scrollbar-thumb":   "#365536",
    "--scrollbar-track":   "#162416",
    "--scrollbar-width":   "8px",

    "--icon-primary":      "#a8d5a2",
    "--icon-secondary":    "#a8c8a8",
    "--icon-muted":        "#6d966d",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "none",
    "--pattern-size":      "auto",
    "--pattern-header":    "none",

    "--card-accent-border": "4px solid #7cb87c",
    "--btn-text-transform": "uppercase",
    "--btn-letter-spacing": "0.06em",
    "--animation-click": "theme-burst 0.18s ease-out"
  }
}
