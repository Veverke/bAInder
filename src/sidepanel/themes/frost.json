{
  "$schema": "./spec.schema.json",
  "name": "Frost",
  "id": "frost",
  "version": "1.0",
  "author": "bAInder",
  "description": "Light frosted-glass panes over a cool sky-to-mint gradient.",
  "category": "blur",
  "dark": false,
  "variables": {
    "--primary":           "#0ea5e9",
    "--primary-hover":     "#38bdf8",
    "--primary-light":     "rgba(14, 165, 233, 0.15)",
    "--primary-dark":      "#0284c7",

    "--header-bg":         "rgba(255, 255, 255, 0.55)",
    "--header-accent":     "#0ea5e9",

    "--bg-primary":        "rgba(255, 255, 255, 0.55)",
    "--bg-secondary":      "rgba(240, 249, 255, 0.50)",
    "--bg-tertiary":       "rgba(224, 242, 254, 0.45)",
    "--bg-elevated":       "rgba(255, 255, 255, 0.70)",
    "--bg-hover":          "rgba(14, 165, 233, 0.08)",
    "--bg-active":         "rgba(14, 165, 233, 0.14)",

    "--border-primary":    "rgba(14, 165, 233, 0.20)",
    "--border-secondary":  "rgba(14, 165, 233, 0.35)",
    "--border-focus":      "#0ea5e9",

    "--text-primary":      "#0c2d48",
    "--text-secondary":    "#1e6090",
    "--text-tertiary":     "#5b9ab8",
    "--text-inverse":      "#ffffff",

    "--success":           "#10b981",
    "--success-bg":        "rgba(16, 185, 129, 0.12)",
    "--warning":           "#f59e0b",
    "--warning-bg":        "rgba(245, 158, 11, 0.12)",
    "--danger":            "#ef4444",
    "--danger-bg":         "rgba(239, 68, 68, 0.12)",
    "--info":              "#6366f1",
    "--info-bg":           "rgba(99, 102, 241, 0.12)",

    "--shadow-sm":         "0 2px 8px rgba(14, 165, 233, 0.12)",
    "--shadow-md":         "0 4px 20px rgba(14, 165, 233, 0.16)",
    "--shadow-lg":         "0 8px 40px rgba(14, 165, 233, 0.20)",
    "--shadow-xl":         "0 16px 64px rgba(14, 165, 233, 0.24)",

    "--overlay":           "rgba(12, 45, 72, 0.60)",
    "--overlay-light":     "rgba(255, 255, 255, 0.40)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "8px",
    "--radius-lg":         "12px",
    "--radius-xl":         "18px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #0ea5e9 0%, #6366f1 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #0ea5e9 0%, #10b981 100%)",
    "--gradient-bg":       "linear-gradient(135deg, #e0f2fe 0%, #f0fdf4 50%, #faf5ff 100%)",
    "--gradient-header":   "linear-gradient(90deg, rgba(255,255,255,0.60) 0%, rgba(240,249,255,0.55) 100%)",

    "--blur-sm":           "blur(8px)",
    "--blur-md":           "blur(18px)",
    "--blur-lg":           "blur(36px)",
    "--glass-bg":          "rgba(255, 255, 255, 0.55)",

    "--page-bg":           "linear-gradient(135deg, #bae6fd 0%, #d1fae5 50%, #ede9fe 100%)",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-normal": "200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-slow":   "360ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0.4, 0, 1, 1)",

    "--focus-ring-color":  "#0ea5e9",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.04em",

    "--code-bg":           "rgba(224, 242, 254, 0.70)",
    "--code-text":         "#0c2d48",
    "--code-keyword":      "#0ea5e9",
    "--code-string":       "#10b981",
    "--code-comment":      "#5b9ab8",
    "--code-number":       "#f59e0b",
    "--code-operator":     "#6366f1",

    "--selection-bg":      "rgba(14, 165, 233, 0.22)",
    "--selection-text":    "#0c2d48",

    "--scrollbar-thumb":   "rgba(14, 165, 233, 0.35)",
    "--scrollbar-track":   "rgba(224, 242, 254, 0.50)",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#0ea5e9",
    "--icon-secondary":    "#38bdf8",
    "--icon-muted":        "#5b9ab8",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(135deg, #bae6fd 0%, #d1fae5 50%, #ede9fe 100%)",
    "--pattern-size":      "auto",
    "--pattern-header":    "linear-gradient(90deg, #bae6fd 0%, #d1fae5 100%)",

    "--card-accent-border": "2px solid #0ea5e9",
    "--btn-letter-spacing": "0.02em"
  }
}
