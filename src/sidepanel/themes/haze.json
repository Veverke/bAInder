{
  "$schema": "./spec.schema.json",
  "name": "Haze",
  "id": "haze",
  "version": "1.0",
  "author": "bAInder",
  "description": "Warm amber frosted glass glowing over a deep bourbon-brown dusk.",
  "category": "blur",
  "dark": true,
  "variables": {
    "--primary":           "#f59e0b",
    "--primary-hover":     "#fbbf24",
    "--primary-light":     "rgba(245, 158, 11, 0.15)",
    "--primary-dark":      "#d97706",

    "--header-bg":         "rgba(28, 16, 4, 0.65)",
    "--header-accent":     "#f59e0b",

    "--bg-primary":        "rgba(28, 16, 4, 0.65)",
    "--bg-secondary":      "rgba(45, 26, 6, 0.55)",
    "--bg-tertiary":       "rgba(68, 38, 8, 0.45)",
    "--bg-elevated":       "rgba(45, 26, 6, 0.75)",
    "--bg-hover":          "rgba(245, 158, 11, 0.08)",
    "--bg-active":         "rgba(245, 158, 11, 0.15)",

    "--border-primary":    "rgba(245, 158, 11, 0.18)",
    "--border-secondary":  "rgba(245, 158, 11, 0.32)",
    "--border-focus":      "#f59e0b",

    "--text-primary":      "#fef3c7",
    "--text-secondary":    "#fbbf24",
    "--text-tertiary":     "#92400e",
    "--text-inverse":      "#1c1004",

    "--success":           "#34d399",
    "--success-bg":        "rgba(52, 211, 153, 0.12)",
    "--warning":           "#f59e0b",
    "--warning-bg":        "rgba(245, 158, 11, 0.12)",
    "--danger":            "#f87171",
    "--danger-bg":         "rgba(248, 113, 113, 0.12)",
    "--info":              "#60a5fa",
    "--info-bg":           "rgba(96, 165, 250, 0.12)",

    "--shadow-sm":         "0 2px 8px rgba(180, 83, 9, 0.20)",
    "--shadow-md":         "0 4px 20px rgba(180, 83, 9, 0.30)",
    "--shadow-lg":         "0 8px 40px rgba(180, 83, 9, 0.38)",
    "--shadow-xl":         "0 16px 64px rgba(180, 83, 9, 0.46)",

    "--overlay":           "rgba(20, 10, 0, 0.82)",
    "--overlay-light":     "rgba(245, 158, 11, 0.06)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "8px",
    "--radius-lg":         "12px",
    "--radius-xl":         "18px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #f59e0b 0%, #ef4444 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%)",
    "--gradient-bg":       "linear-gradient(135deg, #1c1004 0%, #2d1a06 45%, #3d1a02 75%, #1c1004 100%)",
    "--gradient-header":   "linear-gradient(90deg, rgba(28,16,4,0.70) 0%, rgba(45,26,6,0.65) 100%)",

    "--blur-sm":           "blur(8px)",
    "--blur-md":           "blur(18px)",
    "--blur-lg":           "blur(36px)",
    "--glass-bg":          "rgba(28, 16, 4, 0.60)",

    "--page-bg":           "linear-gradient(135deg, #1c1004 0%, #2d1a06 45%, #3d1a02 75%, #1c1004 100%)",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-normal": "200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-slow":   "360ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0.4, 0, 1, 1)",

    "--focus-ring-color":  "#f59e0b",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.04em",

    "--code-bg":           "rgba(20, 10, 2, 0.80)",
    "--code-text":         "#fef3c7",
    "--code-keyword":      "#f59e0b",
    "--code-string":       "#34d399",
    "--code-comment":      "#92400e",
    "--code-number":       "#fbbf24",
    "--code-operator":     "#60a5fa",

    "--selection-bg":      "rgba(245, 158, 11, 0.25)",
    "--selection-text":    "#fef3c7",

    "--scrollbar-thumb":   "rgba(245, 158, 11, 0.35)",
    "--scrollbar-track":   "rgba(28, 16, 4, 0.60)",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#f59e0b",
    "--icon-secondary":    "#fbbf24",
    "--icon-muted":        "#92400e",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(135deg, #1c1004 0%, #2d1a06 45%, #3d1a02 75%, #1c1004 100%)",
    "--pattern-size":      "auto",
    "--pattern-header":    "linear-gradient(90deg, #1c1004 0%, #2d1a06 100%)",

    "--text-glow": "0 0 8px rgba(245,158,11,0.6)",
    "--glow-primary": "0 0 10px #f59e0b, 0 0 20px rgba(245,158,11,0.35)",
    "--card-accent-border": "3px solid #f59e0b",
    "--btn-text-transform": "uppercase",
    "--btn-letter-spacing": "0.06em",
    "--animation-click": "theme-burst 0.18s ease-out",
    "--animation-hover": "theme-glow-pulse 0.5s ease"
  }
}
