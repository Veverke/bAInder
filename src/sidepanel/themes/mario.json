{
  "$schema": "./spec.schema.json",
  "name": "Mario Bros",
  "id": "mario",
  "version": "1.0",
  "author": "bAInder",
  "description": "Mushroom Kingdom delight — bubbly pill-rounded controls, Fredoka One type, brick-wall pattern and platformer drop-shadows.",
  "category": "videogame",
  "dark": true,
  "variables": {
    "--primary":           "#e52222",
    "--primary-hover":     "#ff4444",
    "--primary-light":     "rgba(229,34,34,0.18)",
    "--primary-dark":      "#aa0000",

    "--header-bg":         "linear-gradient(180deg, #5c94fc 0%, #3a72de 100%)",
    "--header-accent":     "#fcfc00",

    "--bg-primary":        "rgba(22,12,40,0.55)",
    "--bg-secondary":      "rgba(30,16,64,0.60)",
    "--bg-tertiary":       "rgba(40,20,85,0.65)",
    "--bg-elevated":       "rgba(50,24,96,0.62)",
    "--bg-hover":          "rgba(229,34,34,0.12)",
    "--bg-active":         "rgba(229,34,34,0.22)",

    "--border-primary":    "#3c2070",
    "--border-secondary":  "#5c94fc",
    "--border-focus":      "#fcfc00",

    "--text-primary":      "#ffffff",
    "--text-secondary":    "#fcfc00",
    "--text-tertiary":     "#8ab0f8",
    "--text-inverse":      "#160c28",

    "--success":           "#3cb43c",
    "--success-bg":        "rgba(60,180,60,0.18)",
    "--warning":           "#fcfc00",
    "--warning-bg":        "rgba(252,252,0,0.18)",
    "--danger":            "#e52222",
    "--danger-bg":         "rgba(229,34,34,0.18)",
    "--info":              "#5c94fc",
    "--info-bg":           "rgba(92,148,252,0.18)",

    "--shadow-sm":         "0 4px 0 rgba(0,0,0,0.45)",
    "--shadow-md":         "0 6px 0 rgba(0,0,0,0.55), 0 8px 20px rgba(0,0,0,0.35)",
    "--shadow-lg":         "0 8px 0 rgba(0,0,0,0.60), 0 12px 30px rgba(0,0,0,0.40)",
    "--shadow-xl":         "0 10px 0 rgba(0,0,0,0.65), 0 16px 40px rgba(0,0,0,0.45)",

    "--overlay":           "rgba(22,12,40,0.90)",
    "--overlay-light":     "rgba(92,148,252,0.12)",

    "--font-sans":         "'Fredoka One', 'Nunito', system-ui, sans-serif",
    "--font-mono":         "'Courier New', Courier, monospace",
    "--font-serif":        "'Fredoka One', Georgia, serif",

    "--radius-xs":         "8px",
    "--radius-sm":         "14px",
    "--radius-md":         "22px",
    "--radius-lg":         "32px",
    "--radius-xl":         "44px",
    "--radius-full":       "999px",

    "--pattern-bg":        "linear-gradient(transparent 50%, rgba(0,0,0,0.14) 50%), repeating-linear-gradient(90deg, rgba(0,0,0,0.12) 0 2px, transparent 2px 60px), repeating-linear-gradient(0deg, rgba(255,255,255,0.04) 0 2px, transparent 2px 32px)",
    "--pattern-size":      "60px 32px",
    "--pattern-header":    "none",

    "--gradient-primary":  "linear-gradient(135deg, #e52222 0%, #ff8800 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #fcfc00 0%, #f8a800 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #160c28 0%, #1e1040 100%)",
    "--gradient-header":   "linear-gradient(180deg, #5c94fc 0%, #3a72de 100%)",

    "--blur-sm":           "blur(0px)",
    "--blur-md":           "blur(0px)",
    "--blur-lg":           "blur(0px)",
    "--glass-bg":          "rgba(0,0,0,0)",

    "--page-bg":           "linear-gradient(180deg, #160c28 0%, #1e1040 100%)",
    "--noise-opacity":     "0",

    "--transition-fast":   "150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-normal": "250ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-slow":   "400ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0.4, 0, 1, 1)",

    "--focus-ring-color":  "#fcfc00",
    "--focus-ring-width":  "3px",
    "--focus-ring-offset": "3px",
    "--focus-ring-style":  "solid",

    "--code-bg":           "rgba(22,12,40,0.88)",
    "--code-text":         "#fcfc00",
    "--code-keyword":      "#e52222",
    "--code-string":       "#3cb43c",
    "--code-comment":      "#5c94fc",
    "--code-number":       "#ff8800",
    "--code-operator":     "#ff8800",

    "--selection-bg":      "rgba(252,252,0,0.30)",
    "--selection-text":    "#160c28",

    "--scrollbar-thumb":   "#5c94fc",
    "--scrollbar-track":   "#1e1040",
    "--scrollbar-width":   "8px",

    "--icon-primary":             "#fcfc00",
    "--icon-secondary":           "#e52222",
    "--icon-muted":               "#5c94fc",

    "--font-display":             "'Fredoka One', 'Nunito', system-ui, sans-serif",
    "--text-glow":                "0 0 12px rgba(252,252,0,0.70)",
    "--image-filter":             "saturate(1.5) contrast(1.1)",
    "--card-accent-border":       "4px solid #e52222",
    "--btn-text-transform":       "uppercase",
    "--btn-letter-spacing":       "0.06em",
    "--animation-click":          "theme-burst 0.18s ease-out",
    "--animation-hover":          "none",
    "--glow-primary":             "0 0 14px rgba(229,34,34,0.70)",

    "--bg-image":          "url('https://static.wikia.nocookie.net/mario/images/d/dc/Mario_%282%29.png/revision/latest?cb=20260203195442')",
    "--bg-image-opacity":  "0.55",
    "--bg-image-blur":     "0px",
    "--bg-image-size":     "70%",
    "--bg-image-position": "center"
  }
}
