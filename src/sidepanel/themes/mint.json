{
  "$schema": "./spec.schema.json",
  "name": "Mint",
  "id": "mint",
  "version": "1.0",
  "author": "bAInder",
  "description": "Deep forest-black gradient rising through fresh mint and cool aqua.",
  "category": "gradient",
  "dark": true,
  "variables": {
    "--primary":           "#00d4a0",
    "--primary-hover":     "#26e0b4",
    "--primary-light":     "rgba(0, 212, 160, 0.15)",
    "--primary-dark":      "#00a880",

    "--header-bg":         "#020e08",
    "--header-accent":     "#00d4a0",

    "--bg-primary":        "#020e08",
    "--bg-secondary":      "#05180e",
    "--bg-tertiary":       "#082014",
    "--bg-elevated":       "#0c2a1a",
    "--bg-hover":          "rgba(0, 212, 160, 0.08)",
    "--bg-active":         "rgba(0, 212, 160, 0.15)",

    "--border-primary":    "#0e3420",
    "--border-secondary":  "#1a5030",
    "--border-focus":      "#00d4a0",

    "--text-primary":      "#ccf5e8",
    "--text-secondary":    "#70c8a0",
    "--text-tertiary":     "#2a6848",
    "--text-inverse":      "#020e08",

    "--success":           "#00d4a0",
    "--success-bg":        "rgba(0, 212, 160, 0.12)",
    "--warning":           "#e8c040",
    "--warning-bg":        "rgba(232, 192, 64, 0.12)",
    "--danger":            "#f06050",
    "--danger-bg":         "rgba(240, 96, 80, 0.12)",
    "--info":              "#40a8d0",
    "--info-bg":           "rgba(64, 168, 208, 0.12)",

    "--shadow-sm":         "0 0 0 1px rgba(0, 212, 160, 0.10)",
    "--shadow-md":         "0 0 16px rgba(0, 212, 160, 0.12)",
    "--shadow-lg":         "0 0 32px rgba(0, 212, 160, 0.16)",
    "--shadow-xl":         "0 0 56px rgba(0, 212, 160, 0.20)",

    "--overlay":           "rgba(2, 14, 8, 0.90)",
    "--overlay-light":     "rgba(0, 212, 160, 0.05)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "6px",
    "--radius-lg":         "10px",
    "--radius-xl":         "14px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #00d4a0 0%, #00a8e8 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #00d4a0 0%, #80e840 100%)",
    "--gradient-bg":       "linear-gradient(160deg, #020e08 0%, #0a2818 35%, #052010 65%, #020e08 100%)",
    "--gradient-header":   "linear-gradient(90deg, #020e08 0%, #081e10 100%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(2, 14, 8, 0.72)",

    "--page-bg":           "linear-gradient(160deg, #020e08 0%, #0a2818 35%, #052010 65%, #020e08 100%)",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-normal": "200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-slow":   "360ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0.4, 0, 1, 1)",

    "--focus-ring-color":  "#00d4a0",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.06em",

    "--code-bg":           "#010b06",
    "--code-text":         "#ccf5e8",
    "--code-keyword":      "#00d4a0",
    "--code-string":       "#70c8a0",
    "--code-comment":      "#2a6848",
    "--code-number":       "#e8c040",
    "--code-operator":     "#40a8d0",

    "--selection-bg":      "rgba(0, 212, 160, 0.25)",
    "--selection-text":    "#ccf5e8",

    "--scrollbar-thumb":   "#1a5030",
    "--scrollbar-track":   "#020e08",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#00d4a0",
    "--icon-secondary":    "#26e0b4",
    "--icon-muted":        "#2a6848",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(160deg, #020e08 0%, #0a2818 35%, #052010 65%, #020e08 100%)",
    "--pattern-size":      "auto",
    "--pattern-header":    "linear-gradient(90deg, #020e08 0%, #081e10 100%)",

    "--text-glow": "0 0 6px rgba(0,212,160,0.5)",
    "--glow-primary": "0 0 10px #00d4a0, 0 0 18px rgba(0,212,160,0.3)",
    "--card-accent-border": "3px solid #00d4a0",
    "--btn-text-transform": "uppercase",
    "--btn-letter-spacing": "0.06em",
    "--animation-click": "theme-burst 0.18s ease-out",
    "--animation-hover": "theme-glow-pulse 0.6s ease"
  }
}
