{
  "$schema": "./spec.schema.json",
  "name": "Mosaic",
  "id": "mosaic",
  "version": "1.0",
  "author": "bAInder",
  "description": "Warm ivory with a delicate checker-tile pattern and bold crimson accents.",
  "category": "pattern",
  "dark": false,
  "variables": {
    "--primary":           "#c0192c",
    "--primary-hover":     "#a01422",
    "--primary-light":     "rgba(192,25,44,0.10)",
    "--primary-dark":      "#800f1c",

    "--header-bg":         "#1a1a2e",
    "--header-accent":     "#f0c060",

    "--bg-primary":        "#faf8f3",
    "--bg-secondary":      "#f0ece0",
    "--bg-tertiary":       "#e6e0d0",
    "--bg-elevated":       "#ffffff",
    "--bg-hover":          "rgba(192,25,44,0.06)",
    "--bg-active":         "rgba(192,25,44,0.12)",

    "--border-primary":    "#d8d0be",
    "--border-secondary":  "#c4b8a0",
    "--border-focus":      "#c0192c",

    "--text-primary":      "#1a1210",
    "--text-secondary":    "#4a3c38",
    "--text-tertiary":     "#8a7a72",
    "--text-inverse":      "#ffffff",

    "--success":           "#2d7a3a",
    "--success-bg":        "rgba(45,122,58,0.10)",
    "--warning":           "#b45309",
    "--warning-bg":        "rgba(180,83,9,0.10)",
    "--danger":            "#c0192c",
    "--danger-bg":         "rgba(192,25,44,0.10)",
    "--info":              "#1e5fb4",
    "--info-bg":           "rgba(30,95,180,0.10)",

    "--shadow-sm":         "0 1px 3px rgba(26,18,16,0.10)",
    "--shadow-md":         "0 4px 12px rgba(26,18,16,0.12)",
    "--shadow-lg":         "0 8px 24px rgba(26,18,16,0.14)",
    "--shadow-xl":         "0 16px 40px rgba(26,18,16,0.16)",

    "--overlay":           "rgba(26,18,16,0.55)",
    "--overlay-light":     "rgba(26,18,16,0.12)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "3px",
    "--radius-sm":         "4px",
    "--radius-md":         "6px",
    "--radius-lg":         "10px",
    "--radius-xl":         "14px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #c0192c 0%, #e63950 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #f0c060 0%, #c0192c 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #faf8f3 0%, #f0ece0 100%)",
    "--gradient-header":   "linear-gradient(135deg, #1a1a2e 0%, #2a2a44 100%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(250,248,243,0.80)",

    "--page-bg":           "#faf8f3",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-normal": "200ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-slow":   "360ms cubic-bezier(0.4,0,0.2,1)",
    "--easing-standard":   "cubic-bezier(0.4,0,0.2,1)",
    "--easing-decelerate": "cubic-bezier(0,0,0.2,1)",
    "--easing-accelerate": "cubic-bezier(0.4,0,1,1)",

    "--focus-ring-color":  "#c0192c",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.06em",

    "--code-bg":           "#f0ece0",
    "--code-text":         "#1a1210",
    "--code-keyword":      "#c0192c",
    "--code-string":       "#2d7a3a",
    "--code-comment":      "#8a7a72",
    "--code-number":       "#b45309",
    "--code-operator":     "#4a3c38",

    "--selection-bg":      "rgba(192,25,44,0.20)",
    "--selection-text":    "#1a1210",

    "--scrollbar-thumb":   "#c4b8a0",
    "--scrollbar-track":   "#f0ece0",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#c0192c",
    "--icon-secondary":    "#4a3c38",
    "--icon-muted":        "#8a7a72",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "repeating-conic-gradient(rgba(192,25,44,0.05) 0 45deg, transparent 0 90deg)",
    "--pattern-size":      "24px 24px",
    "--pattern-header":    "repeating-conic-gradient(rgba(240,192,96,0.12) 0 45deg, transparent 0 90deg)",

    "--card-accent-border": "3px solid #c0192c"
  }
}
