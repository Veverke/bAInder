{
  "$schema": "./spec.schema.json",
  "name": "Neon",
  "id": "neon",
  "version": "1.0",
  "author": "bAInder",
  "description": "Cyberpunk near-black base with electric cyan and magenta glows.",
  "category": "solid",
  "dark": true,
  "variables": {
    "--primary":           "#00fff5",
    "--primary-hover":     "#00cccc",
    "--primary-light":     "rgba(0, 255, 245, 0.15)",
    "--primary-dark":      "#00aaaa",

    "--header-bg":         "#0a0a0f",
    "--header-accent":     "#00fff5",

    "--bg-primary":        "#0a0a0f",
    "--bg-secondary":      "#0f0f16",
    "--bg-tertiary":       "#14141e",
    "--bg-elevated":       "#111120",
    "--bg-hover":          "rgba(0, 255, 245, 0.07)",
    "--bg-active":         "rgba(0, 255, 245, 0.14)",

    "--border-primary":    "#1a1a2e",
    "--border-secondary":  "rgba(0, 255, 245, 0.25)",
    "--border-focus":      "#00fff5",

    "--text-primary":      "#e0e0ff",
    "--text-secondary":    "#9090c0",
    "--text-tertiary":     "#4a4a7a",
    "--text-inverse":      "#0a0a0f",

    "--success":           "#00fff5",
    "--success-bg":        "rgba(0, 255, 245, 0.10)",
    "--warning":           "#ff00c8",
    "--warning-bg":        "rgba(255, 0, 200, 0.10)",
    "--danger":            "#ff0055",
    "--danger-bg":         "rgba(255, 0, 85, 0.10)",
    "--info":              "#aa00ff",
    "--info-bg":           "rgba(170, 0, 255, 0.10)",

    "--shadow-sm":         "0 0 8px rgba(0, 255, 245, 0.10)",
    "--shadow-md":         "0 0 20px rgba(0, 255, 245, 0.15)",
    "--shadow-lg":         "0 0 36px rgba(0, 255, 245, 0.20)",
    "--shadow-xl":         "0 0 56px rgba(0, 255, 245, 0.25)",

    "--overlay":           "rgba(0, 0, 0, 0.85)",
    "--overlay-light":     "rgba(0, 255, 245, 0.05)",

    "--gradient-primary":  "linear-gradient(135deg, #00fff5 0%, #aa00ff 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #ff00c8 0%, #aa00ff 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #0a0a0f 0%, #0f0f1a 100%)",
    "--gradient-header":   "linear-gradient(90deg, #0a0a0f 0%, #0f0f2a 100%)",

    "--blur-sm":           "blur(2px)",
    "--blur-md":           "blur(6px)",
    "--blur-lg":           "blur(14px)",
    "--glass-bg":          "rgba(0, 255, 245, 0.05)",

    "--page-bg":           "#0a0a0f",
    "--noise-opacity":     "0",

    "--transition-fast":   "150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-normal": "250ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-slow":   "400ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0.4, 0, 1, 1)",

    "--focus-ring-color":  "#00fff5",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.5",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.05em",

    "--code-bg":           "#0f0f16",
    "--code-text":         "#e0e0ff",
    "--code-keyword":      "#ff00c8",
    "--code-string":       "#00fff5",
    "--code-comment":      "#4a4a7a",
    "--code-number":       "#aa00ff",
    "--code-operator":     "#ff0055",

    "--selection-bg":      "rgba(0, 255, 245, 0.25)",
    "--selection-text":    "#0a0a0f",

    "--scrollbar-thumb":   "rgba(0, 255, 245, 0.4)",
    "--scrollbar-track":   "#0f0f16",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#00fff5",
    "--icon-secondary":    "#9090c0",
    "--icon-muted":        "#4a4a7a",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "none",
    "--pattern-size":      "auto",
    "--pattern-header":    "none",

    "--text-glow": "0 0 10px #00fff5, 0 0 22px rgba(0,255,245,0.4)",
    "--glow-primary": "0 0 12px #00fff5, 0 0 24px rgba(0,255,245,0.35)",
    "--card-accent-border": "3px solid #00fff5",
    "--btn-text-transform": "uppercase",
    "--btn-letter-spacing": "0.12em",
    "--animation-click": "theme-burst 0.15s ease-out",
    "--animation-hover": "theme-glow-pulse 0.5s ease"
  }
}
