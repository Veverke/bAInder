{
  "$schema": "./spec.schema.json",
  "name": "Nord",
  "id": "nord",
  "version": "1.0",
  "author": "bAInder",
  "description": "Arctic palette with cool slate-blues and Aurora accent colours.",
  "category": "solid",
  "dark": true,
  "variables": {
    "--primary":           "#88c0d0",
    "--primary-hover":     "#8fbcbb",
    "--primary-light":     "rgba(136, 192, 208, 0.15)",
    "--primary-dark":      "#5e81ac",

    "--header-bg":         "#2e3440",
    "--header-accent":     "#88c0d0",

    "--bg-primary":        "#2e3440",
    "--bg-secondary":      "#3b4252",
    "--bg-tertiary":       "#434c5e",
    "--bg-elevated":       "#4c566a",
    "--bg-hover":          "rgba(136, 192, 208, 0.08)",
    "--bg-active":         "rgba(136, 192, 208, 0.15)",

    "--border-primary":    "#3b4252",
    "--border-secondary":  "#4c566a",
    "--border-focus":      "#88c0d0",

    "--text-primary":      "#eceff4",
    "--text-secondary":    "#d8dee9",
    "--text-tertiary":     "#9aa3b2",
    "--text-inverse":      "#2e3440",

    "--success":           "#a3be8c",
    "--success-bg":        "rgba(163, 190, 140, 0.12)",
    "--warning":           "#ebcb8b",
    "--warning-bg":        "rgba(235, 203, 139, 0.12)",
    "--danger":            "#bf616a",
    "--danger-bg":         "rgba(191, 97, 106, 0.12)",
    "--info":              "#81a1c1",
    "--info-bg":           "rgba(129, 161, 193, 0.12)",

    "--shadow-sm":         "0 1px 4px rgba(0, 0, 0, 0.28)",
    "--shadow-md":         "0 4px 16px rgba(0, 0, 0, 0.32)",
    "--shadow-lg":         "0 8px 28px rgba(0, 0, 0, 0.36)",
    "--shadow-xl":         "0 16px 44px rgba(0, 0, 0, 0.40)",

    "--overlay":           "rgba(46, 52, 64, 0.92)",
    "--overlay-light":     "rgba(136, 192, 208, 0.05)",

    "--gradient-primary":  "linear-gradient(135deg, #88c0d0 0%, #81a1c1 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #88c0d0 0%, #b48ead 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #2e3440 0%, #3b4252 100%)",
    "--gradient-header":   "linear-gradient(135deg, #2e3440 0%, #3b4252 100%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(46, 52, 64, 0.7)",

    "--page-bg":           "#2e3440",
    "--noise-opacity":     "0",

    "--transition-fast":   "150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-normal": "250ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-slow":   "400ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0.4, 0, 1, 1)",

    "--focus-ring-color":  "#88c0d0",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.5",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.05em",

    "--code-bg":           "#3b4252",
    "--code-text":         "#eceff4",
    "--code-keyword":      "#81a1c1",
    "--code-string":       "#a3be8c",
    "--code-comment":      "#4c566a",
    "--code-number":       "#b48ead",
    "--code-operator":     "#88c0d0",

    "--selection-bg":      "rgba(136, 192, 208, 0.3)",
    "--selection-text":    "#eceff4",

    "--scrollbar-thumb":   "#4c566a",
    "--scrollbar-track":   "#3b4252",
    "--scrollbar-width":   "8px",

    "--icon-primary":      "#88c0d0",
    "--icon-secondary":    "#d8dee9",
    "--icon-muted":        "#9aa3b2",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "none",
    "--pattern-size":      "auto",
    "--pattern-header":    "none",

    "--card-accent-border": "3px solid #88c0d0",
    "--btn-letter-spacing": "0.02em"
  }
}
