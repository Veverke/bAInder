{
  "$schema": "./spec.schema.json",
  "name": "Prism",
  "id": "prism",
  "version": "1.0",
  "author": "bAInder",
  "description": "Multi-hue deep-dark gradient cycling indigo, sapphire, teal and violet.",
  "category": "gradient",
  "dark": true,
  "variables": {
    "--primary":           "#a855f7",
    "--primary-hover":     "#bc7aff",
    "--primary-light":     "rgba(168,85,247,0.15)",
    "--primary-dark":      "#8830e8",

    "--header-bg":         "#080a14",
    "--header-accent":     "#a855f7",

    "--bg-primary":        "#080a14",
    "--bg-secondary":      "#0e0e22",
    "--bg-tertiary":       "#141430",
    "--bg-elevated":       "#1a1840",
    "--bg-hover":          "rgba(168,85,247,0.08)",
    "--bg-active":         "rgba(168,85,247,0.15)",

    "--border-primary":    "#201e40",
    "--border-secondary":  "rgba(168,85,247,0.28)",
    "--border-focus":      "#a855f7",

    "--text-primary":      "#e8d8ff",
    "--text-secondary":    "#a888d8",
    "--text-tertiary":     "#504870",
    "--text-inverse":      "#080a14",

    "--success":           "#10d090",
    "--success-bg":        "rgba(16,208,144,0.12)",
    "--warning":           "#f0c040",
    "--warning-bg":        "rgba(240,192,64,0.12)",
    "--danger":            "#f04060",
    "--danger-bg":         "rgba(240,64,96,0.12)",
    "--info":              "#40b0f0",
    "--info-bg":           "rgba(64,176,240,0.12)",

    "--shadow-sm":         "0 0 8px rgba(168,85,247,0.10)",
    "--shadow-md":         "0 0 20px rgba(168,85,247,0.15)",
    "--shadow-lg":         "0 0 36px rgba(168,85,247,0.20)",
    "--shadow-xl":         "0 0 56px rgba(168,85,247,0.25)",

    "--overlay":           "rgba(8,10,20,0.90)",
    "--overlay-light":     "rgba(168,85,247,0.05)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "6px",
    "--radius-lg":         "10px",
    "--radius-xl":         "14px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #a855f7 0%, #40b0f0 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #10d090 0%, #a855f7 100%)",
    "--gradient-bg":       "linear-gradient(135deg, #0a0420 0%, #081428 25%, #040e10 50%, #180820 75%, #0a0420 100%)",
    "--gradient-header":   "linear-gradient(90deg, #080a14 0%, #0e0e22 100%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(8,10,20,0.72)",

    "--page-bg":           "linear-gradient(135deg, #0a0420 0%, #081428 25%, #040e10 50%, #180820 75%, #0a0420 100%)",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-normal": "200ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-slow":   "360ms cubic-bezier(0.4,0,0.2,1)",
    "--easing-standard":   "cubic-bezier(0.4,0,0.2,1)",
    "--easing-decelerate": "cubic-bezier(0,0,0.2,1)",
    "--easing-accelerate": "cubic-bezier(0.4,0,1,1)",

    "--focus-ring-color":  "#a855f7",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.06em",

    "--code-bg":           "#060810",
    "--code-text":         "#e8d8ff",
    "--code-keyword":      "#a855f7",
    "--code-string":       "#10d090",
    "--code-comment":      "#504870",
    "--code-number":       "#f0c040",
    "--code-operator":     "#40b0f0",

    "--selection-bg":      "rgba(168,85,247,0.25)",
    "--selection-text":    "#e8d8ff",

    "--scrollbar-thumb":   "#201e40",
    "--scrollbar-track":   "#080a14",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#a855f7",
    "--icon-secondary":    "#bc7aff",
    "--icon-muted":        "#504870",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(135deg, #0a0420 0%, #081428 25%, #040e10 50%, #180820 75%, #0a0420 100%)",
    "--pattern-size":      "auto",
    "--pattern-header":    "linear-gradient(90deg, #080a14 0%, #0e0e22 100%)",

    "--text-glow": "0 0 10px rgba(168,85,247,0.7)",
    "--glow-primary": "0 0 14px #a855f7, 0 0 24px rgba(168,85,247,0.4)",
    "--card-accent-border": "3px solid #a855f7",
    "--btn-letter-spacing": "0.04em",
    "--animation-click": "theme-burst 0.18s ease-out",
    "--animation-hover": "theme-glow-pulse 0.5s ease"
  }
}
