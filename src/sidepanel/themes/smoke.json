{
  "$schema": "./spec.schema.json",
  "name": "Smoke",
  "id": "smoke",
  "version": "1.0",
  "author": "bAInder",
  "description": "Dark charcoal frosted glass with cool slate tones.",
  "category": "blur",
  "dark": true,
  "variables": {
    "--primary":           "#94a3b8",
    "--primary-hover":     "#cbd5e1",
    "--primary-light":     "rgba(148, 163, 184, 0.15)",
    "--primary-dark":      "#64748b",

    "--header-bg":         "rgba(15, 23, 42, 0.65)",
    "--header-accent":     "#94a3b8",

    "--bg-primary":        "rgba(15, 23, 42, 0.65)",
    "--bg-secondary":      "rgba(30, 41, 59, 0.55)",
    "--bg-tertiary":       "rgba(51, 65, 85, 0.45)",
    "--bg-elevated":       "rgba(30, 41, 59, 0.75)",
    "--bg-hover":          "rgba(148, 163, 184, 0.08)",
    "--bg-active":         "rgba(148, 163, 184, 0.14)",

    "--border-primary":    "rgba(148, 163, 184, 0.15)",
    "--border-secondary":  "rgba(148, 163, 184, 0.28)",
    "--border-focus":      "#94a3b8",

    "--text-primary":      "#e2e8f0",
    "--text-secondary":    "#94a3b8",
    "--text-tertiary":     "#475569",
    "--text-inverse":      "#0f172a",

    "--success":           "#34d399",
    "--success-bg":        "rgba(52, 211, 153, 0.12)",
    "--warning":           "#fbbf24",
    "--warning-bg":        "rgba(251, 191, 36, 0.12)",
    "--danger":            "#f87171",
    "--danger-bg":         "rgba(248, 113, 113, 0.12)",
    "--info":              "#60a5fa",
    "--info-bg":           "rgba(96, 165, 250, 0.12)",

    "--shadow-sm":         "0 2px 8px rgba(0, 0, 0, 0.30)",
    "--shadow-md":         "0 4px 20px rgba(0, 0, 0, 0.40)",
    "--shadow-lg":         "0 8px 40px rgba(0, 0, 0, 0.50)",
    "--shadow-xl":         "0 16px 64px rgba(0, 0, 0, 0.60)",

    "--overlay":           "rgba(2, 6, 23, 0.80)",
    "--overlay-light":     "rgba(148, 163, 184, 0.06)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "8px",
    "--radius-lg":         "12px",
    "--radius-xl":         "18px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #94a3b8 0%, #60a5fa 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #94a3b8 0%, #34d399 100%)",
    "--gradient-bg":       "linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #0f172a 100%)",
    "--gradient-header":   "linear-gradient(90deg, rgba(15,23,42,0.70) 0%, rgba(30,41,59,0.65) 100%)",

    "--blur-sm":           "blur(8px)",
    "--blur-md":           "blur(18px)",
    "--blur-lg":           "blur(36px)",
    "--glass-bg":          "rgba(15, 23, 42, 0.60)",

    "--page-bg":           "linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #0f172a 100%)",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-normal": "200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-slow":   "360ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0.4, 0, 1, 1)",

    "--focus-ring-color":  "#94a3b8",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.04em",

    "--code-bg":           "rgba(15, 23, 42, 0.80)",
    "--code-text":         "#e2e8f0",
    "--code-keyword":      "#94a3b8",
    "--code-string":       "#34d399",
    "--code-comment":      "#475569",
    "--code-number":       "#fbbf24",
    "--code-operator":     "#60a5fa",

    "--selection-bg":      "rgba(148, 163, 184, 0.22)",
    "--selection-text":    "#e2e8f0",

    "--scrollbar-thumb":   "rgba(148, 163, 184, 0.30)",
    "--scrollbar-track":   "rgba(15, 23, 42, 0.60)",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#94a3b8",
    "--icon-secondary":    "#cbd5e1",
    "--icon-muted":        "#475569",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #0f172a 100%)",
    "--pattern-size":      "auto",
    "--pattern-header":    "linear-gradient(90deg, #0f172a 0%, #1e293b 100%)",

    "--card-accent-border": "2px solid #94a3b8",
    "--btn-text-transform": "uppercase",
    "--btn-letter-spacing": "0.04em",
    "--animation-click": "theme-burst 0.18s ease-out"
  }
}
