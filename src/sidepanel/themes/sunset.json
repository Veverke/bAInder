{
  "$schema": "./spec.schema.json",
  "name": "Sunset",
  "id": "sunset",
  "version": "1.0",
  "author": "bAInder",
  "description": "Deep indigo twilight melting through magenta into burning coral orange.",
  "category": "gradient",
  "dark": true,
  "variables": {
    "--primary":           "#ff6b35",
    "--primary-hover":     "#ff8550",
    "--primary-light":     "rgba(255,107,53,0.15)",
    "--primary-dark":      "#e05020",

    "--header-bg":         "#0d0526",
    "--header-accent":     "#ff6b35",

    "--bg-primary":        "#0d0526",
    "--bg-secondary":      "#180a38",
    "--bg-tertiary":       "#220e48",
    "--bg-elevated":       "#2c1258",
    "--bg-hover":          "rgba(255,107,53,0.08)",
    "--bg-active":         "rgba(255,107,53,0.16)",

    "--border-primary":    "#3a1860",
    "--border-secondary":  "rgba(255,107,53,0.30)",
    "--border-focus":      "#ff6b35",

    "--text-primary":      "#ffe8d8",
    "--text-secondary":    "#e8a080",
    "--text-tertiary":     "#885040",
    "--text-inverse":      "#0d0526",

    "--success":           "#40c080",
    "--success-bg":        "rgba(64,192,128,0.12)",
    "--warning":           "#ffd060",
    "--warning-bg":        "rgba(255,208,96,0.12)",
    "--danger":            "#ff4060",
    "--danger-bg":         "rgba(255,64,96,0.12)",
    "--info":              "#a060ff",
    "--info-bg":           "rgba(160,96,255,0.12)",

    "--shadow-sm":         "0 0 8px rgba(255,107,53,0.10)",
    "--shadow-md":         "0 0 20px rgba(255,107,53,0.15)",
    "--shadow-lg":         "0 0 36px rgba(255,107,53,0.20)",
    "--shadow-xl":         "0 0 56px rgba(255,107,53,0.25)",

    "--overlay":           "rgba(13,5,38,0.90)",
    "--overlay-light":     "rgba(255,107,53,0.06)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "6px",
    "--radius-lg":         "10px",
    "--radius-xl":         "14px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #ff6b35 0%, #a040c0 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #ffd060 0%, #ff6b35 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #0d0526 0%, #3d1a5e 40%, #8b2a52 70%, #c84010 100%)",
    "--gradient-header":   "linear-gradient(90deg, #0d0526 0%, #3d1a5e 100%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(13,5,38,0.72)",

    "--page-bg":           "linear-gradient(180deg, #0d0526 0%, #3d1a5e 35%, #8b2a52 65%, #c84010 90%)",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-normal": "200ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-slow":   "360ms cubic-bezier(0.4,0,0.2,1)",
    "--easing-standard":   "cubic-bezier(0.4,0,0.2,1)",
    "--easing-decelerate": "cubic-bezier(0,0,0.2,1)",
    "--easing-accelerate": "cubic-bezier(0.4,0,1,1)",

    "--focus-ring-color":  "#ff6b35",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.06em",

    "--code-bg":           "#0a0320",
    "--code-text":         "#ffe8d8",
    "--code-keyword":      "#ff6b35",
    "--code-string":       "#40c080",
    "--code-comment":      "#885040",
    "--code-number":       "#ffd060",
    "--code-operator":     "#a060ff",

    "--selection-bg":      "rgba(255,107,53,0.25)",
    "--selection-text":    "#ffe8d8",

    "--scrollbar-thumb":   "#3a1860",
    "--scrollbar-track":   "#0d0526",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#ff6b35",
    "--icon-secondary":    "#ff8550",
    "--icon-muted":        "#885040",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(180deg, #0d0526 0%, #3d1a5e 35%, #8b2a52 65%, #c84010 90%)",
    "--pattern-size":      "auto",
    "--pattern-header":    "linear-gradient(90deg, #0d0526 0%, #3d1a5e 100%)",

    "--text-glow": "0 0 10px rgba(255,107,53,0.65)",
    "--glow-primary": "0 0 12px #ff6b35, 0 0 22px rgba(255,107,53,0.35)",
    "--card-accent-border": "3px solid #ff6b35",
    "--btn-letter-spacing": "0.04em",
    "--animation-click": "theme-burst 0.18s ease-out",
    "--animation-hover": "theme-glow-pulse 0.5s ease"
  }
}
