{
  "$schema": "./spec.schema.json",
  "name": "Tartan",
  "id": "tartan",
  "version": "1.0",
  "author": "bAInder",
  "description": "Warm ivory with g58-inspired criss-cross diagonal tartan stripes in sienna and cream.",
  "category": "pattern",
  "dark": false,
  "variables": {
    "--primary":           "#8b4513",
    "--primary-hover":     "#a0521e",
    "--primary-light":     "rgba(139,69,19,0.10)",
    "--primary-dark":      "#6b3410",

    "--header-bg":         "linear-gradient(135deg, #3a1a0a 0%, #5e2d0e 100%)",
    "--header-accent":     "#d4a050",

    "--bg-primary":        "#fdf8f0",
    "--bg-secondary":      "#f5ede0",
    "--bg-tertiary":       "#e8dcc8",
    "--bg-elevated":       "#ffffff",
    "--bg-hover":          "rgba(139,69,19,0.06)",
    "--bg-active":         "rgba(139,69,19,0.12)",

    "--border-primary":    "#d8c8b0",
    "--border-secondary":  "#c0a888",
    "--border-focus":      "#8b4513",

    "--text-primary":      "#2a1a0e",
    "--text-secondary":    "#5c3820",
    "--text-tertiary":     "#9a7058",
    "--text-inverse":      "#ffffff",

    "--success":           "#4a7a2a",
    "--success-bg":        "rgba(74,122,42,0.10)",
    "--warning":           "#b48030",
    "--warning-bg":        "rgba(180,128,48,0.10)",
    "--danger":            "#c0451a",
    "--danger-bg":         "rgba(192,69,26,0.10)",
    "--info":              "#3a6090",
    "--info-bg":           "rgba(58,96,144,0.10)",

    "--shadow-sm":         "0 1px 2px rgba(42,26,14,0.08)",
    "--shadow-md":         "0 4px 10px rgba(42,26,14,0.10)",
    "--shadow-lg":         "0 8px 22px rgba(42,26,14,0.12)",
    "--shadow-xl":         "0 16px 38px rgba(42,26,14,0.15)",

    "--overlay":           "rgba(42,26,14,0.50)",
    "--overlay-light":     "rgba(42,26,14,0.10)",

    "--font-sans":         "'Inter', -apple-system, system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "6px",
    "--radius-lg":         "10px",
    "--radius-xl":         "14px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #8b4513 0%, #c07030 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #d4a050 0%, #8b4513 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #fdf8f0 0%, #f8f0e0 100%)",
    "--gradient-header":   "linear-gradient(90deg, #3a1a0a 0%, #5e2d0e 100%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(253,248,240,0.85)",

    "--page-bg":           "#fdf8f0",
    "--noise-opacity":     "0",

    "--transition-fast":   "100ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-normal": "200ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-slow":   "360ms cubic-bezier(0.4,0,0.2,1)",
    "--easing-standard":   "cubic-bezier(0.4,0,0.2,1)",
    "--easing-decelerate": "cubic-bezier(0,0,0.2,1)",
    "--easing-accelerate": "cubic-bezier(0.4,0,1,1)",

    "--focus-ring-color":  "#8b4513",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, 'Times New Roman', serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "600",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.06em",

    "--code-bg":           "#f0e8d8",
    "--code-text":         "#2a1a0e",
    "--code-keyword":      "#8b4513",
    "--code-string":       "#4a7a2a",
    "--code-comment":      "#9a7058",
    "--code-number":       "#c0451a",
    "--code-operator":     "#3a6090",

    "--selection-bg":      "rgba(139,69,19,0.20)",
    "--selection-text":    "#2a1a0e",

    "--scrollbar-thumb":   "#c0a888",
    "--scrollbar-track":   "#fdf8f0",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#8b4513",
    "--icon-secondary":    "#b46030",
    "--icon-muted":        "#9a7058",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(135deg, transparent 18.75%, rgba(94,65,47,0.14) 0 31.25%, transparent 0), repeating-linear-gradient(45deg, rgba(94,65,47,0.10) -6.25% 6.25%, rgba(252,235,182,0.20) 0 18.75%)",
    "--pattern-size":      "120px 120px",
    "--pattern-header":    "linear-gradient(135deg, transparent 18.75%, rgba(212,160,80,0.20) 0 31.25%, transparent 0), repeating-linear-gradient(45deg, rgba(212,160,80,0.16) -6.25% 6.25%, rgba(252,235,182,0.25) 0 18.75%)",

    "--card-accent-border": "3px solid #8b4513"
  }
}
