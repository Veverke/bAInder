{
  "$schema": "./spec.schema.json",
  "name": "Terminal",
  "id": "terminal",
  "version": "1.0",
  "author": "bAInder",
  "description": "Phosphor green on pure black. Monospace. CRT vibes.",
  "category": "solid",
  "dark": true,
  "variables": {
    "--primary":           "#00ff41",
    "--primary-hover":     "#00cc33",
    "--primary-light":     "rgba(0, 255, 65, 0.15)",
    "--primary-dark":      "#009925",

    "--header-bg":         "#000000",
    "--header-accent":     "#00ff41",

    "--bg-primary":        "#000000",
    "--bg-secondary":      "#0a0a0a",
    "--bg-tertiary":       "#111111",
    "--bg-elevated":       "#0d0d0d",
    "--bg-hover":          "rgba(0, 255, 65, 0.08)",
    "--bg-active":         "rgba(0, 255, 65, 0.16)",

    "--border-primary":    "#1a3a1a",
    "--border-secondary":  "#00ff41",
    "--border-focus":      "#00ff41",

    "--text-primary":      "#00ff41",
    "--text-secondary":    "#00cc33",
    "--text-tertiary":     "#006617",
    "--text-inverse":      "#000000",

    "--success":           "#00ff41",
    "--success-bg":        "rgba(0, 255, 65, 0.12)",
    "--warning":           "#ffcc00",
    "--warning-bg":        "rgba(255, 204, 0, 0.12)",
    "--danger":            "#ff4444",
    "--danger-bg":         "rgba(255, 68, 68, 0.12)",
    "--info":              "#00ddff",
    "--info-bg":           "rgba(0, 221, 255, 0.12)",

    "--shadow-sm":         "none",
    "--shadow-md":         "0 0 12px rgba(0, 255, 65, 0.15)",
    "--shadow-lg":         "0 0 24px rgba(0, 255, 65, 0.2)",
    "--shadow-xl":         "0 0 40px rgba(0, 255, 65, 0.25)",

    "--overlay":           "rgba(0, 0, 0, 0.88)",
    "--overlay-light":     "rgba(0, 255, 65, 0.05)",

    "--font-sans":         "'Courier Prime', 'Courier New', Courier, 'Lucida Console', monospace",

    "--gradient-primary":  "linear-gradient(135deg, #00ff41 0%, #00cc33 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #00ff41 0%, #00ddff 100%)",
    "--gradient-bg":       "none",
    "--gradient-header":   "none",

    "--blur-sm":           "blur(0px)",
    "--blur-md":           "blur(0px)",
    "--blur-lg":           "blur(0px)",
    "--glass-bg":          "rgba(0, 0, 0, 0)",

    "--page-bg":           "#000000",
    "--noise-opacity":     "0.04",

    "--transition-fast":   "80ms cubic-bezier(0, 0, 0.2, 1)",
    "--transition-normal": "160ms cubic-bezier(0, 0, 0.2, 1)",
    "--transition-slow":   "300ms cubic-bezier(0, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0, 0, 0.2, 1)",

    "--focus-ring-color":  "#00ff41",
    "--focus-ring-width":  "1px",
    "--focus-ring-offset": "0px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Courier Prime', 'Courier New', Courier, 'Lucida Console', monospace",
    "--font-serif":               "'Courier New', Courier, monospace",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "700",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "0em",
    "--letter-spacing-wide":      "0.08em",

    "--code-bg":           "#000000",
    "--code-text":         "#00ff41",
    "--code-keyword":      "#00ddff",
    "--code-string":       "#00ff41",
    "--code-comment":      "#006617",
    "--code-number":       "#ffcc00",
    "--code-operator":     "#00cc33",

    "--selection-bg":      "rgba(0, 255, 65, 0.3)",
    "--selection-text":    "#000000",

    "--scrollbar-thumb":   "#00ff41",
    "--scrollbar-track":   "#0a0a0a",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#00ff41",
    "--icon-secondary":    "#00cc33",
    "--icon-muted":        "#006617",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "repeating-linear-gradient(transparent 0 3px, rgba(0,255,65,0.10) 3px 4px)",
    "--pattern-size":      "auto",
    "--pattern-header":    "repeating-linear-gradient(transparent 0 3px, rgba(0,255,65,0.14) 3px 4px)",

    "--font-display": "'Courier Prime', 'Courier New', Courier, monospace",
    "--image-filter": "grayscale(1) contrast(1.3) brightness(0.85)",
    "--text-glow": "0 0 6px #00ff41",
    "--glow-primary": "0 0 8px #00ff41, 0 0 16px rgba(0,255,65,0.3)",
    "--card-accent-border": "2px solid #00ff41",
    "--btn-text-transform": "uppercase",
    "--btn-letter-spacing": "0.10em",
    "--animation-click": "theme-burst 0.15s ease-out",
    "--animation-hover": "theme-glow-pulse 0.4s ease"
  }
}
