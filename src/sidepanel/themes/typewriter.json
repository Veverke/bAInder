{
  "$schema": "./spec.schema.json",
  "name": "Typewriter",
  "id": "typewriter",
  "version": "1.0",
  "author": "bAInder",
  "description": "Worn sepia paper and Special Elite type — an old-school typewriter aesthetic.",
  "category": "solid",
  "dark": false,
  "variables": {
    "--primary":           "#8b3a2a",
    "--primary-hover":     "#a04535",
    "--primary-light":     "rgba(139,58,42,0.12)",
    "--primary-dark":      "#6e2d20",

    "--header-bg":         "#2c1a0e",
    "--header-accent":     "#c8a050",

    "--bg-primary":        "#f5f0e8",
    "--bg-secondary":      "#ede5d4",
    "--bg-tertiary":       "#e0d4be",
    "--bg-elevated":       "#faf6ee",
    "--bg-hover":          "rgba(139,58,42,0.07)",
    "--bg-active":         "rgba(139,58,42,0.14)",

    "--border-primary":    "#c8b89c",
    "--border-secondary":  "#a89078",
    "--border-focus":      "#8b3a2a",

    "--text-primary":      "#1a0f00",
    "--text-secondary":    "#4a3020",
    "--text-tertiary":     "#8a7060",
    "--text-inverse":      "#f5f0e8",

    "--success":           "#4a7a3a",
    "--success-bg":        "rgba(74,122,58,0.12)",
    "--warning":           "#b08030",
    "--warning-bg":        "rgba(176,128,48,0.12)",
    "--danger":            "#8b3a2a",
    "--danger-bg":         "rgba(139,58,42,0.12)",
    "--info":              "#3a5a8b",
    "--info-bg":           "rgba(58,90,139,0.12)",

    "--shadow-sm":         "2px 2px 4px rgba(26,15,0,0.15)",
    "--shadow-md":         "3px 3px 8px rgba(26,15,0,0.18)",
    "--shadow-lg":         "4px 4px 14px rgba(26,15,0,0.20)",
    "--shadow-xl":         "6px 6px 20px rgba(26,15,0,0.22)",

    "--overlay":           "rgba(26,15,0,0.55)",
    "--overlay-light":     "rgba(26,15,0,0.12)",

    "--font-sans":         "'Special Elite', 'Courier New', cursive",
    "--font-mono":         "'Courier New', Courier, monospace",
    "--font-serif":        "'Special Elite', Georgia, serif",
    "--font-size-base":    "15px",
    "--font-size-sm":      "13px",
    "--font-size-lg":      "17px",
    "--font-weight-normal":"400",
    "--font-weight-bold":  "700",
    "--line-height-base":  "1.7",
    "--letter-spacing-tight": "-0.01em",
    "--letter-spacing-wide":  "0.06em",

    "--radius-xs":         "1px",
    "--radius-sm":         "2px",
    "--radius-md":         "2px",
    "--radius-lg":         "3px",
    "--radius-xl":         "4px",
    "--radius-full":       "2px",

    "--gradient-primary":  "none",
    "--gradient-accent":   "none",
    "--gradient-bg":       "none",
    "--gradient-header":   "none",

    "--blur-sm":           "blur(0px)",
    "--blur-md":           "blur(0px)",
    "--blur-lg":           "blur(0px)",
    "--glass-bg":          "rgba(245,240,232,0)",

    "--page-bg":           "#f5f0e8",
    "--noise-opacity":     "0",

    "--transition-fast":   "80ms",
    "--transition-normal": "150ms",
    "--transition-slow":   "280ms",
    "--easing-standard":   "ease-in-out",
    "--easing-decelerate": "ease-out",
    "--easing-accelerate": "ease-in",

    "--focus-ring-color":  "#8b3a2a",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--code-bg":           "#e8dfc8",
    "--code-text":         "#1a0f00",
    "--code-keyword":      "#8b3a2a",
    "--code-string":       "#4a7a3a",
    "--code-comment":      "#8a7060",
    "--code-number":       "#b08030",
    "--code-operator":     "#3a5a8b",

    "--selection-bg":      "rgba(139,58,42,0.25)",
    "--selection-text":    "#1a0f00",

    "--scrollbar-thumb":   "#c8b89c",
    "--scrollbar-track":   "#ede5d4",
    "--scrollbar-width":   "8px",

    "--icon-primary":      "#8b3a2a",
    "--icon-secondary":    "#c8a050",
    "--icon-muted":        "#8a7060",

    "--pattern-bg":        "repeating-linear-gradient(transparent 0px 27px, rgba(26,15,0,0.06) 27px 28px)",
    "--pattern-size":      "auto",
    "--pattern-header":    "none",

    "--font-display": "'Special Elite', 'Courier New', cursive",
    "--image-filter": "sepia(0.4) contrast(1.05)",
    "--card-accent-border": "3px solid #8b3a2a",
    "--btn-text-transform": "capitalize",
    "--btn-letter-spacing": "0.04em",
    "--animation-click": "theme-burst 0.18s ease-out"
  }
}
