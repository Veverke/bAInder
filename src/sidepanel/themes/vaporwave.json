{
  "$schema": "./spec.schema.json",
  "name": "Vaporwave",
  "id": "vaporwave",
  "version": "1.0",
  "author": "bAInder",
  "description": "Synthwave '84. Deep purple with hot-pink and cyan neon, diagonal stripe pattern.",
  "category": "pattern",
  "dark": true,
  "variables": {
    "--primary":           "#ff71ce",
    "--primary-hover":     "#ff9dda",
    "--primary-light":     "rgba(255,113,206,0.15)",
    "--primary-dark":      "#cc45a8",

    "--header-bg":         "linear-gradient(135deg, #0d0221 0%, #1f0649 100%)",
    "--header-accent":     "#01cdfe",

    "--bg-primary":        "#0d0221",
    "--bg-secondary":      "#130530",
    "--bg-tertiary":       "#1a073e",
    "--bg-elevated":       "#20094c",
    "--bg-hover":          "rgba(255,113,206,0.08)",
    "--bg-active":         "rgba(255,113,206,0.16)",

    "--border-primary":    "#2d1060",
    "--border-secondary":  "rgba(255,113,206,0.30)",
    "--border-focus":      "#ff71ce",

    "--text-primary":      "#ffecff",
    "--text-secondary":    "#bf8fff",
    "--text-tertiary":     "#6040a0",
    "--text-inverse":      "#0d0221",

    "--success":           "#05ffa1",
    "--success-bg":        "rgba(5,255,161,0.10)",
    "--warning":           "#fffb96",
    "--warning-bg":        "rgba(255,251,150,0.10)",
    "--danger":            "#ff6b6b",
    "--danger-bg":         "rgba(255,107,107,0.10)",
    "--info":              "#01cdfe",
    "--info-bg":           "rgba(1,205,254,0.10)",

    "--shadow-sm":         "0 0 8px rgba(255,113,206,0.18)",
    "--shadow-md":         "0 0 20px rgba(255,113,206,0.22)",
    "--shadow-lg":         "0 0 36px rgba(255,113,206,0.28)",
    "--shadow-xl":         "0 0 56px rgba(255,113,206,0.34)",

    "--overlay":           "rgba(13,2,33,0.90)",
    "--overlay-light":     "rgba(255,113,206,0.06)",

    "--font-sans":         "'Inter', system-ui, sans-serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "6px",
    "--radius-lg":         "10px",
    "--radius-xl":         "16px",
    "--radius-full":       "9999px",

    "--gradient-primary":  "linear-gradient(135deg, #ff71ce 0%, #01cdfe 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #01cdfe 0%, #b967ff 100%)",
    "--gradient-bg":       "linear-gradient(180deg, #0d0221 0%, #1a073e 100%)",
    "--gradient-header":   "linear-gradient(135deg, #0d0221 0%, #1f0649 100%)",

    "--blur-sm":           "blur(4px)",
    "--blur-md":           "blur(8px)",
    "--blur-lg":           "blur(16px)",
    "--glass-bg":          "rgba(13,2,33,0.65)",

    "--page-bg":           "#0d0221",
    "--noise-opacity":     "0",

    "--transition-fast":   "120ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-normal": "220ms cubic-bezier(0.4,0,0.2,1)",
    "--transition-slow":   "380ms cubic-bezier(0.4,0,0.2,1)",
    "--easing-standard":   "cubic-bezier(0.4,0,0.2,1)",
    "--easing-decelerate": "cubic-bezier(0,0,0.2,1)",
    "--easing-accelerate": "cubic-bezier(0.4,0,1,1)",

    "--focus-ring-color":  "#ff71ce",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--font-mono":                "'Cascadia Code', 'Fira Code', Consolas, monospace",
    "--font-serif":               "Georgia, serif",
    "--font-size-base":           "14px",
    "--font-size-sm":             "12px",
    "--font-size-lg":             "16px",
    "--font-weight-normal":       "400",
    "--font-weight-bold":         "700",
    "--line-height-base":         "1.6",
    "--letter-spacing-tight":     "-0.01em",
    "--letter-spacing-wide":      "0.08em",

    "--code-bg":           "#130530",
    "--code-text":         "#ffecff",
    "--code-keyword":      "#ff71ce",
    "--code-string":       "#05ffa1",
    "--code-comment":      "#6040a0",
    "--code-number":       "#fffb96",
    "--code-operator":     "#01cdfe",

    "--selection-bg":      "rgba(255,113,206,0.28)",
    "--selection-text":    "#ffecff",

    "--scrollbar-thumb":   "rgba(255,113,206,0.40)",
    "--scrollbar-track":   "#130530",
    "--scrollbar-width":   "6px",

    "--icon-primary":      "#ff71ce",
    "--icon-secondary":    "#01cdfe",
    "--icon-muted":        "#6040a0",

    "--spacing-xs":        "4px",
    "--spacing-sm":        "8px",
    "--spacing-md":        "16px",
    "--spacing-lg":        "24px",
    "--spacing-xl":        "40px",

    "--z-dropdown":        "100",
    "--z-modal":           "200",
    "--z-toast":           "300",
    "--z-tooltip":         "400",
    "--z-overlay":         "150",

    "--pattern-bg":        "linear-gradient(-26.56deg, rgba(255,113,206,0.08) 33%, rgba(1,205,254,0.08) 33.3% 66.6%, rgba(255,113,206,0.08) 67%)",
    "--pattern-size":      "80px 80px",
    "--pattern-header":    "linear-gradient(-26.56deg, rgba(255,113,206,0.14) 33%, rgba(1,205,254,0.14) 33.3% 66.6%, rgba(255,113,206,0.14) 67%)",

    "--text-glow": "0 0 12px #ff71ce, 0 0 24px rgba(1,205,254,0.45)",
    "--glow-primary": "0 0 14px #ff71ce, 0 0 28px rgba(255,113,206,0.35)",
    "--card-accent-border": "3px solid #ff71ce",
    "--btn-text-transform": "uppercase",
    "--btn-letter-spacing": "0.10em",
    "--animation-click": "theme-burst 0.18s ease-out",
    "--animation-hover": "theme-glow-pulse 0.6s ease"
  }
}
