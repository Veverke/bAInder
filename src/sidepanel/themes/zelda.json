{
  "$schema": "./spec.schema.json",
  "name": "Zelda",
  "id": "zelda",
  "version": "1.0",
  "author": "bAInder",
  "description": "Hyrule's golden legacy — Cinzel Decorative royal type, sacred triangle pattern, warm forest depths and Triforce-gold illumination.",
  "category": "videogame",
  "dark": true,
  "dependencies": { "fonts": ["Cinzel Decorative"], "requiredBaseVersion": "1.1" },
  "variables": {
    "--primary":           "#d4a017",
    "--primary-hover":     "#e8b830",
    "--primary-light":     "rgba(212,160,23,0.15)",
    "--primary-dark":      "#a87e0d",

    "--header-bg":         "#140c00",
    "--header-accent":     "#d4a017",

    "--bg-primary":        "rgba(8,14,4,0.55)",
    "--bg-secondary":      "rgba(14,22,8,0.60)",
    "--bg-tertiary":       "rgba(22,32,16,0.65)",
    "--bg-elevated":       "rgba(28,44,20,0.62)",
    "--bg-hover":          "rgba(212,160,23,0.08)",
    "--bg-active":         "rgba(212,160,23,0.16)",

    "--border-primary":    "#243818",
    "--border-secondary":  "rgba(212,160,23,0.28)",
    "--border-focus":      "#d4a017",

    "--text-primary":      "#f0e8cc",
    "--text-secondary":    "#b8a880",
    "--text-tertiary":     "#5a5030",
    "--text-inverse":      "#080e04",

    "--success":           "#6ab840",
    "--success-bg":        "rgba(106,184,64,0.12)",
    "--warning":           "#d4a017",
    "--warning-bg":        "rgba(212,160,23,0.12)",
    "--danger":            "#c04040",
    "--danger-bg":         "rgba(192,64,64,0.12)",
    "--info":              "#6090c8",
    "--info-bg":           "rgba(96,144,200,0.12)",

    "--shadow-sm":         "0 2px 8px rgba(0,0,0,0.50), 0 0 4px rgba(212,160,23,0.08)",
    "--shadow-md":         "0 4px 16px rgba(0,0,0,0.60), 0 0 12px rgba(212,160,23,0.12)",
    "--shadow-lg":         "0 8px 30px rgba(0,0,0,0.70), 0 0 22px rgba(212,160,23,0.16)",
    "--shadow-xl":         "0 14px 48px rgba(0,0,0,0.80), 0 0 36px rgba(212,160,23,0.20)",

    "--overlay":           "rgba(8,14,4,0.92)",
    "--overlay-light":     "rgba(212,160,23,0.06)",

    "--font-sans":         "'Cinzel Decorative', 'Palatino Linotype', serif",
    "--font-mono":         "'Courier New', Courier, monospace",
    "--font-serif":        "'Cinzel Decorative', 'Palatino Linotype', serif",

    "--radius-xs":         "2px",
    "--radius-sm":         "4px",
    "--radius-md":         "8px",
    "--radius-lg":         "12px",
    "--radius-xl":         "16px",
    "--radius-full":       "12px",

    "--pattern-bg":        "linear-gradient(60deg, transparent 40%, rgba(212,160,23,0.05) 40% 60%, transparent 60%), linear-gradient(-60deg, transparent 40%, rgba(212,160,23,0.05) 40% 60%, transparent 60%)",
    "--pattern-size":      "44px 25px",
    "--pattern-header":    "linear-gradient(60deg, transparent 40%, rgba(212,160,23,0.12) 40% 60%, transparent 60%), linear-gradient(-60deg, transparent 40%, rgba(212,160,23,0.12) 40% 60%, transparent 60%)",

    "--gradient-primary":  "linear-gradient(135deg, #d4a017 0%, #6ab840 100%)",
    "--gradient-accent":   "linear-gradient(135deg, #d4a017 0%, #e8b830 100%)",
    "--gradient-bg":       "radial-gradient(ellipse at 50% 0%, #1c2c14 0%, #080e04 70%)",
    "--gradient-header":   "linear-gradient(180deg, #140c00 0%, #080e04 100%)",

    "--blur-sm":           "blur(0px)",
    "--blur-md":           "blur(0px)",
    "--blur-lg":           "blur(0px)",
    "--glass-bg":          "rgba(0,0,0,0)",

    "--page-bg":           "radial-gradient(ellipse at 50% 0%, #1c2c14 0%, #080e04 70%)",
    "--noise-opacity":     "0",

    "--transition-fast":   "150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-normal": "250ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--transition-slow":   "400ms cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
    "--easing-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
    "--easing-accelerate": "cubic-bezier(0.4, 0, 1, 1)",

    "--focus-ring-color":  "#d4a017",
    "--focus-ring-width":  "2px",
    "--focus-ring-offset": "2px",
    "--focus-ring-style":  "solid",

    "--code-bg":           "rgba(8,14,4,0.90)",
    "--code-text":         "#f0e8cc",
    "--code-keyword":      "#d4a017",
    "--code-string":       "#6ab840",
    "--code-comment":      "#5a5030",
    "--code-number":       "#6090c8",
    "--code-operator":     "#c04040",

    "--selection-bg":      "rgba(212,160,23,0.28)",
    "--selection-text":    "#f0e8cc",

    "--scrollbar-thumb":   "rgba(212,160,23,0.44)",
    "--scrollbar-track":   "rgba(8,14,4,0.70)",
    "--scrollbar-width":   "6px",

    "--icon-primary":             "#d4a017",
    "--icon-secondary":           "#b8a880",
    "--icon-muted":               "#5a5030",

    "--font-display":             "'Cinzel Decorative', 'Palatino Linotype', serif",
    "--text-glow":                "0 0 14px rgba(212,160,23,0.50)",
    "--image-filter":             "sepia(0.20) saturate(1.10)",
    "--card-accent-border":       "3px solid #d4a017",
    "--btn-text-transform":       "none",
    "--btn-letter-spacing":       "0.06em",
    "--animation-click":          "theme-bounce 0.22s ease",
    "--animation-hover":          "none",
    "--glow-primary":             "0 0 14px rgba(212,160,23,0.60)",

    "--bg-image":          "url('https://freepngimg.com/save/webp/21344-zelda-link-transparent-background')",
    "--bg-image-opacity":  "0.55",
    "--bg-image-blur":     "0px",
    "--bg-image-size":     "cover",
    "--bg-image-position": "center"
  }
}
