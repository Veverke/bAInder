{
  "$schema": "./spec.schema.json",
  "name": "Forest",
  "id": "forest",
  "version": "1.0",
  "author": "bAInder",
  "description": "Deep woodland greens with warm amber accents.",
  "variables": {
    "--primary":           "#7cb87c",
    "--primary-hover":     "#8fca8f",
    "--primary-light":     "rgba(124, 184, 124, 0.15)",
    "--primary-dark":      "#568f56",

    "--header-bg":         "#0e1a0e",
    "--header-accent":     "#a8d5a2",

    "--bg-primary":        "#0e1a0e",
    "--bg-secondary":      "#162416",
    "--bg-tertiary":       "#1c2d1c",
    "--bg-elevated":       "#213521",
    "--bg-hover":          "rgba(124, 184, 124, 0.08)",
    "--bg-active":         "rgba(124, 184, 124, 0.16)",

    "--border-primary":    "#243824",
    "--border-secondary":  "#365536",
    "--border-focus":      "#7cb87c",

    "--text-primary":      "#d4ecd4",
    "--text-secondary":    "#a8c8a8",
    "--text-tertiary":     "#6d966d",
    "--text-inverse":      "#0e1a0e",

    "--success":           "#a8d5a2",
    "--success-bg":        "rgba(168, 213, 162, 0.12)",
    "--warning":           "#d4a640",
    "--warning-bg":        "rgba(212, 166, 64, 0.12)",
    "--danger":            "#cc6666",
    "--danger-bg":         "rgba(204, 102, 102, 0.12)",
    "--info":              "#6baed6",
    "--info-bg":           "rgba(107, 174, 214, 0.12)",

    "--shadow-sm":         "0 1px 4px rgba(0, 0, 0, 0.30)",
    "--shadow-md":         "0 4px 16px rgba(0, 0, 0, 0.35)",
    "--shadow-lg":         "0 8px 28px rgba(0, 0, 0, 0.40)",
    "--shadow-xl":         "0 16px 44px rgba(0, 0, 0, 0.45)",

    "--overlay":           "rgba(14, 26, 14, 0.92)",
    "--overlay-light":     "rgba(124, 184, 124, 0.05)"
  }
}
