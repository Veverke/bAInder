{
  "$schema": "./spec.schema.json",
  "name": "Retro 8-bit",
  "id": "retro",
  "version": "1.0",
  "author": "bAInder",
  "description": "NES-inspired palette with pixel borders and gold accents.",
  "variables": {
    "--primary":           "#ffcc00",
    "--primary-hover":     "#ffa500",
    "--primary-light":     "rgba(255, 204, 0, 0.2)",
    "--primary-dark":      "#cc9900",

    "--header-bg":         "#000080",
    "--header-accent":     "#ffcc00",

    "--bg-primary":        "#0a001a",
    "--bg-secondary":      "#000060",
    "--bg-tertiary":       "#00004a",
    "--bg-elevated":       "#000080",
    "--bg-hover":          "#0000aa",
    "--bg-active":         "#0000cc",

    "--border-primary":    "#5555ff",
    "--border-secondary":  "#aaaaff",
    "--border-focus":      "#ffcc00",

    "--text-primary":      "#ffffff",
    "--text-secondary":    "#aaaaff",
    "--text-tertiary":     "#5555ff",
    "--text-inverse":      "#000000",

    "--success":           "#55ff55",
    "--success-bg":        "#003300",
    "--warning":           "#ffcc00",
    "--warning-bg":        "#333300",
    "--danger":            "#ff5555",
    "--danger-bg":         "#330000",
    "--info":              "#55ffff",
    "--info-bg":           "#003333",

    "--shadow-sm":         "3px 3px 0px #000",
    "--shadow-md":         "4px 4px 0px #000",
    "--shadow-lg":         "6px 6px 0px #000",
    "--shadow-xl":         "8px 8px 0px #000",

    "--overlay":           "rgba(0, 0, 0, 0.9)",
    "--overlay-light":     "rgba(0, 0, 170, 0.4)",

    "--font-sans":         "'PressStart2P', 'Courier New', monospace",

    "--radius-xs":         "0px",
    "--radius-sm":         "0px",
    "--radius-md":         "0px",
    "--radius-lg":         "0px",
    "--radius-xl":         "0px",
    "--radius-full":       "0px"
  }
}
