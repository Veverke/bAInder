{
  "$schema": "./spec.schema.json",
  "name": "Solarized Dark",
  "id": "solarized",
  "version": "1.0",
  "author": "bAInder",
  "description": "Ethan Schoonover's classic warm teal-green dark palette.",
  "variables": {
    "--primary":           "#268bd2",
    "--primary-hover":     "#2aa198",
    "--primary-light":     "rgba(38, 139, 210, 0.15)",
    "--primary-dark":      "#1a6fa3",

    "--header-bg":         "#073642",
    "--header-accent":     "#268bd2",

    "--bg-primary":        "#002b36",
    "--bg-secondary":      "#073642",
    "--bg-tertiary":       "#0a3f4d",
    "--bg-elevated":       "#0d4a5a",
    "--bg-hover":          "rgba(38, 139, 210, 0.08)",
    "--bg-active":         "rgba(38, 139, 210, 0.16)",

    "--border-primary":    "#073642",
    "--border-secondary":  "#0e5060",
    "--border-focus":      "#268bd2",

    "--text-primary":      "#93a1a1",
    "--text-secondary":    "#839496",
    "--text-tertiary":     "#586e75",
    "--text-inverse":      "#002b36",

    "--success":           "#859900",
    "--success-bg":        "rgba(133, 153, 0, 0.12)",
    "--warning":           "#b58900",
    "--warning-bg":        "rgba(181, 137, 0, 0.12)",
    "--danger":            "#dc322f",
    "--danger-bg":         "rgba(220, 50, 47, 0.12)",
    "--info":              "#2aa198",
    "--info-bg":           "rgba(42, 161, 152, 0.12)",

    "--shadow-sm":         "0 1px 4px rgba(0, 0, 0, 0.35)",
    "--shadow-md":         "0 4px 16px rgba(0, 0, 0, 0.40)",
    "--shadow-lg":         "0 8px 28px rgba(0, 0, 0, 0.45)",
    "--shadow-xl":         "0 16px 44px rgba(0, 0, 0, 0.50)",

    "--overlay":           "rgba(0, 43, 54, 0.93)",
    "--overlay-light":     "rgba(38, 139, 210, 0.05)"
  }
}
